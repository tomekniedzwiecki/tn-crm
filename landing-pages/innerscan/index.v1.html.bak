  <!-- FAQ -->
  <!-- VIDEOS:REELS:START -->
  <style>
    /* ═══ SEKCJA REELS ═══ */
    .reels {
      position: relative;
      padding: 80px 0 64px;
      background: linear-gradient(180deg, #0F172A 0%, #1A1A2E 50%, #0F172A 100%);
      overflow: hidden;
      color: #fff;
    }
    .reels::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 20% 30%, rgba(0, 168, 150, 0.18) 0%, transparent 50%),
        radial-gradient(circle at 80% 70%, rgba(247, 127, 0, 0.15) 0%, transparent 50%);
      pointer-events: none;
    }
    .reels .container { position: relative; z-index: 1; }

    .reels-header {
      text-align: center;
      max-width: 720px;
      margin: 0 auto 48px;
    }
    .reels-header .section-label { color: var(--accent, #80FFDB); }
    .reels-header .section-label::before { background: linear-gradient(90deg, var(--accent, #80FFDB), transparent); }
    .reels-header .section-title {
      color: #fff;
      font-size: clamp(28px, 4vw, 44px);
      margin-bottom: 16px;
    }
    .reels-header .section-subtitle {
      color: rgba(255, 255, 255, 0.65);
      font-size: 17px;
      max-width: 560px;
      margin: 0 auto;
    }

    /* Stage z phone-mockupami (5 widocznych: aktywny + 2 z każdej strony) */
    .reels-stage {
      position: relative;
      width: 100%;
      height: 560px;
      overflow: hidden;
      -webkit-mask-image: linear-gradient(to right, transparent 0, #000 12%, #000 88%, transparent 100%);
              mask-image: linear-gradient(to right, transparent 0, #000 12%, #000 88%, transparent 100%);
    }
    .reels-track {
      position: absolute;
      top: 50%;
      left: 50%;
      display: flex;
      gap: 24px;
      align-items: center;
      transform: translate(-50%, -50%);
      transition: transform 0.6s cubic-bezier(0.32, 0.72, 0, 1);
      will-change: transform;
    }

    .reel-phone {
      flex-shrink: 0;
      width: 280px;
      aspect-ratio: 9 / 16;
      max-height: 500px;
      border-radius: 32px;
      background: linear-gradient(135deg, #1A1A2E 0%, #0a0a14 100%);
      padding: 8px;
      position: relative;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 0 1.5px rgba(255, 255, 255, 0.05);
      transition: transform 0.6s cubic-bezier(0.32, 0.72, 0, 1), opacity 0.5s ease, filter 0.5s ease, box-shadow 0.5s ease;
      cursor: pointer;
      border: none;
      color: inherit;
      transform: scale(0.5);
      opacity: 0.25;
      filter: blur(3px) saturate(0.7);
    }
    .reel-phone--peek-far { transform: scale(0.5); opacity: 0.25; filter: blur(3px) saturate(0.7); }
    .reel-phone--peek      { transform: scale(0.7); opacity: 0.6;  filter: blur(1px) saturate(0.85); }
    .reel-phone--active    {
      transform: scale(1);
      opacity: 1;
      filter: none;
      box-shadow:
        0 32px 64px rgba(0, 0, 0, 0.55),
        0 0 0 2px var(--primary, #00A896),
        0 0 60px rgba(0, 168, 150, 0.3);
      z-index: 2;
    }
    .reel-phone--active:hover {
      box-shadow:
        0 36px 72px rgba(0, 0, 0, 0.65),
        0 0 0 2px var(--primary-light, #00C4AE),
        0 0 80px rgba(0, 168, 150, 0.45);
    }

    /* Phone notch (Dynamic Island) */
    .reel-phone::before {
      content: '';
      position: absolute;
      top: 14px;
      left: 50%;
      transform: translateX(-50%);
      width: 78px;
      height: 18px;
      background: #000;
      border-radius: 12px;
      z-index: 3;
      pointer-events: none;
    }

    .reel-phone-screen {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 24px;
      overflow: hidden;
      background: #000;
    }
    .reel-phone-thumb {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .reel-phone-player {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }
    /* Crop hack dla YouTube Shorts: iframe szerszy (16:9 ratio) wysrodkowany w 9:16 frame.
       UWAGA: YT.Player REPLACES div w DOM, wiec iframe staje sie direct child .reel-phone-screen
       (klasa .reel-phone-player ginie po replacement) — selektor musi targetowac przez parent screen. */
    .reel-phone-screen { overflow: hidden; }
    .reel-phone-screen > iframe,
    .reel-phone-player iframe {
      position: absolute !important;
      top: 50% !important;
      left: 50% !important;
      height: 100% !important;
      width: 177.778% !important;
      transform: translate(-50%, -50%) !important;
      border: 0 !important;
      pointer-events: none !important;
    }

    /* Play button overlay (znika gdy phone aktywnie odtwarza) */
    .reel-phone-play {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) scale(1);
      width: 60px;
      height: 60px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.95);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
      z-index: 2;
      transition: opacity 0.3s ease, transform 0.3s ease;
    }
    .reel-phone-play svg {
      width: 22px;
      height: 22px;
      color: var(--primary, #00A896);
      margin-left: 3px;
    }
    .reel-phone--playing .reel-phone-play {
      opacity: 0;
      pointer-events: none;
    }
    .reel-phone--active:hover .reel-phone-play {
      transform: translate(-50%, -50%) scale(1.1);
      background: var(--primary, #00A896);
    }
    .reel-phone--active:hover .reel-phone-play svg { color: #fff; }

    @media (max-width: 720px) {
      .reels { padding: 56px 0 48px; }
      .reels-stage { height: 460px; }
      .reels-track { gap: 16px; }
      .reel-phone { width: 220px; max-height: 400px; border-radius: 28px; padding: 7px; }
      .reel-phone::before { top: 11px; width: 64px; height: 15px; }
      .reel-phone--peek { transform: scale(0.45); opacity: 0.35; filter: blur(2px); }
      .reel-phone--peek-far { display: none; }
      .reel-phone-play { width: 50px; height: 50px; }
      .reel-phone-play svg { width: 18px; height: 18px; }
    }
    @media (max-width: 420px) {
      .reels-stage { height: 420px; }
      .reel-phone { width: 200px; max-height: 360px; }
    }

    /* Progress bars (zamiast dots) — wizualizują postęp aktywnego video */
    .reels-progress {
      display: flex;
      gap: 6px;
      max-width: 360px;
      margin: 32px auto 28px;
      padding: 0 16px;
    }
    .reels-progress-bar {
      flex: 1;
      height: 3px;
      background: rgba(255, 255, 255, 0.14);
      border-radius: 2px;
      cursor: pointer;
      overflow: hidden;
      position: relative;
      border: none;
      padding: 0;
    }
    .reels-progress-bar > span {
      display: block;
      height: 100%;
      width: 0;
      background: var(--primary-light, #00C4AE);
      border-radius: 2px;
      transition: width 0.15s linear;
    }
    .reels-progress-bar--filled > span { width: 100% !important; }

    /* CTA pod video */
    .reels-cta-wrap { text-align: center; max-width: 480px; margin: 0 auto; }
    .reels-cta {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 20px 44px;
      background: linear-gradient(135deg, var(--primary, #00A896) 0%, var(--secondary, #F77F00) 100%);
      color: #fff;
      font-family: var(--font-heading, system-ui);
      font-size: 17px;
      font-weight: 700;
      text-decoration: none;
      border-radius: 14px;
      box-shadow: 0 16px 40px rgba(0, 168, 150, 0.4);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      animation: reels-cta-pulse 2.6s ease-in-out infinite;
    }
    .reels-cta:hover {
      transform: translateY(-3px) scale(1.03);
      box-shadow: 0 20px 50px rgba(0, 168, 150, 0.55);
      animation-play-state: paused;
    }
    .reels-cta svg { width: 20px; height: 20px; }
    @keyframes reels-cta-pulse {
      0%, 100% { box-shadow: 0 16px 40px rgba(0, 168, 150, 0.4); }
      50%      { box-shadow: 0 16px 40px rgba(0, 168, 150, 0.4), 0 0 60px rgba(0, 168, 150, 0.5); }
    }
    @media (prefers-reduced-motion: reduce) { .reels-cta { animation: none; } }
    .reels-cta-hint { margin-top: 14px; color: rgba(255, 255, 255, 0.55); font-size: 13px; }

    /* ═══ LIGHTBOX (full-screen, snap-scroll vertical, IG/TT-style) ═══ */
    .reels-lightbox {
      position: fixed;
      inset: 0;
      background: radial-gradient(ellipse at center, #1a1a2e 0%, #000 100%);
      z-index: 10000;
      display: none;
      flex-direction: column;
      overscroll-behavior: contain;
    }
    .reels-lightbox.show {
      display: flex;
      animation: reels-lb-fade 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    @keyframes reels-lb-fade {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    .reels-lb-close {
      position: absolute;
      top: 20px;
      right: 20px;
      z-index: 10;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: #fff;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      line-height: 1;
      backdrop-filter: blur(12px);
      transition: background 0.2s, transform 0.2s;
    }
    .reels-lb-close:hover {
      background: rgba(255, 255, 255, 0.22);
      transform: scale(1.06);
    }

    .reels-lb-counter {
      position: absolute;
      top: 24px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      color: #fff;
      font-family: var(--font-body, system-ui);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.04em;
      background: rgba(0, 0, 0, 0.5);
      padding: 8px 16px;
      border-radius: 999px;
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .reels-lb-scroll {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
      scroll-snap-type: y mandatory;
      scroll-behavior: smooth;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .reels-lb-scroll::-webkit-scrollbar { display: none; }

    .reels-lb-slide {
      width: 100%;
      height: 100vh;
      height: 100dvh;
      scroll-snap-align: start;
      scroll-snap-stop: always;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      padding: 24px 16px 110px;
      box-sizing: border-box;
    }

    .reels-lb-frame {
      position: relative;
      width: 100%;
      max-width: 380px;
      aspect-ratio: 9 / 16;
      max-height: calc(100vh - 170px);
      max-height: calc(100dvh - 170px);
      background: #000;
      border-radius: 22px;
      overflow: hidden;
      box-shadow:
        0 32px 80px rgba(0, 0, 0, 0.7),
        0 0 0 1px rgba(255, 255, 255, 0.08),
        inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    }
    .reels-lb-player {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }
    /* Ten sam crop hack co w sekcji — iframe 16:9 width w 9:16 frame.
       YT.Player replaces div, wiec selektor przez parent .reels-lb-frame. */
    .reels-lb-frame > iframe,
    .reels-lb-player iframe {
      position: absolute !important;
      top: 50% !important;
      left: 50% !important;
      height: 100% !important;
      width: 177.778% !important;
      transform: translate(-50%, -50%) !important;
      border: 0 !important;
    }

    .reels-lb-link {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      text-decoration: none;
      color: #fff;
      font-family: var(--font-heading, system-ui);
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
    }
    .reels-lb-link-icon {
      width: 80px;
      height: 80px;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .reels-lb-link-icon--instagram { background: linear-gradient(135deg, #833AB4, #FD1D1D, #FCB045); }
    .reels-lb-link-icon--tiktok { background: linear-gradient(135deg, #000, #25F4EE, #FE2C55); }
    .reels-lb-link-icon svg { width: 40px; height: 40px; color: #fff; }
    .reels-lb-link-label { font-size: 18px; font-weight: 700; }
    .reels-lb-link-sub { font-size: 13px; color: rgba(255, 255, 255, 0.6); }

    /* Sticky CTA na dole każdego slajdu */
    .reels-lb-slide-cta {
      position: absolute;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%);
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 32px;
      background: linear-gradient(135deg, var(--primary, #00A896) 0%, var(--secondary, #F77F00) 100%);
      color: #fff;
      font-family: var(--font-heading, system-ui);
      font-weight: 700;
      font-size: 14px;
      text-decoration: none;
      border-radius: 999px;
      box-shadow: 0 16px 40px rgba(0, 168, 150, 0.5);
      z-index: 4;
      white-space: nowrap;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .reels-lb-slide-cta:hover {
      transform: translateX(-50%) translateY(-2px) scale(1.02);
      box-shadow: 0 20px 48px rgba(0, 168, 150, 0.65);
    }
    .reels-lb-slide-cta svg { width: 16px; height: 16px; }

    .reels-lb-hint {
      position: absolute;
      bottom: 8px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 5;
      color: rgba(255, 255, 255, 0.35);
      font-family: var(--font-body, system-ui);
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      pointer-events: none;
    }
    @media (max-width: 720px) {
      .reels-lb-hint { display: none; }
      .reels-lb-frame {
        max-height: calc(100vh - 150px);
        max-height: calc(100dvh - 150px);
        border-radius: 18px;
      }
      .reels-lb-slide-cta { padding: 14px 24px; font-size: 13px; bottom: 20px; }
      .reels-lb-counter { top: 16px; font-size: 11px; padding: 6px 12px; }
      .reels-lb-close { top: 16px; right: 16px; width: 40px; height: 40px; font-size: 20px; }
    }

    /* ═══ Mobile polish: widgety + narrow screens + horizontal overflow ═══ */
    html { overflow-x: hidden; max-width: 100vw }
    @media (max-width: 720px) {
      .header { box-shadow: 0 2px 8px rgba(13,33,55,0.06) !important }
      .stories-bar { top: 58px !important; border-top: 1px solid rgba(13,33,55,0.06) !important }
      .wa-widget { bottom: 100px !important }
      .reviews-side-widget { bottom: 100px !important }
    }
    @media (max-width: 480px) {
      .wa-teaser { display: none !important }
      .wa-widget { right: 10px !important }
      .reviews-side-widget { left: 10px !important }
      .sticky-cta { padding: 8px 12px !important; gap: 8px !important }
      .sticky-cta-price { font-size: 14px !important }
      .sticky-cta-price small { font-size: 7px !important; letter-spacing: .12em !important }
      .sticky-cta .btn { padding: 10px 14px !important; font-size: 10px !important }
    }
  </style>

