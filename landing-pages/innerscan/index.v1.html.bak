<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>InnerScan - Kamera Endoskopowa Dual Lens z Ekranem 4.3"</title>
  <meta name="description" content="Profesjonalna kamera endoskopowa z podwójnym obiektywem Dual Lens i ekranem IPS 4.3 cala. Diagnozuj ukryte usterki w silnikach, rurach i ścianach bez kosztownego demontażu.">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%23ffffff'/%3E%3Cpath d='M18.5 6L10 17h6l-2.5 9L22 15h-6l2.5-9z' fill='%23000000'/%3E%3C/svg%3E">

  <!-- Open Graph -->
  <meta property="og:title" content="InnerScan - Kamera Endoskopowa Dual Lens">
  <meta property="og:description" content="Zobacz więcej. Napraw szybciej. Profesjonalna kamera inspekcyjna z podwójnym obiektywem.">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="pl_PL">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <style>
    :root {
      /* Brand Colors */
      --primary: #00D4FF;
      --primary-rgb: 0, 212, 255;
      --secondary: #0A1628;
      --secondary-rgb: 10, 22, 40;
      --accent: #FF6B35;
      --accent-rgb: 255, 107, 53;
      --neutral-dark: #1A1F2E;
      --neutral-mid: #4A5568;
      --neutral-light: #E2E8F0;

      /* Derived */
      --primary-soft: rgba(0, 212, 255, 0.08);
      --primary-glow: rgba(0, 212, 255, 0.25);
      --secondary-soft: rgba(10, 22, 40, 0.05);

      /* Light theme — with warmth */
      --bg-white: #FEFEFE;
      --bg-alt: #F8FAFC;
      --text-dark: #0D1117;
      --text-secondary: #5C6470;
      --border-light: #E2E6EB;

      /* Typography */
      --font-heading: 'Space Grotesk', sans-serif;
      --font-body: 'IBM Plex Sans', sans-serif;
      --font-accent: 'JetBrains Mono', monospace;

      /* Spacing & Radius */
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --radius-xl: 24px;

      /* Shadows — with color */
      --shadow-sm: 0 1px 2px rgba(10, 22, 40, 0.06);
      --shadow-md: 0 4px 12px rgba(10, 22, 40, 0.08);
      --shadow-lg: 0 10px 30px rgba(0, 212, 255, 0.12);
      --shadow-xl: 0 20px 50px rgba(0, 212, 255, 0.18);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: var(--font-body);
      color: var(--text-dark);
      background: var(--bg-white);
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* Utility Classes */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .section-label {
      font-family: var(--font-accent);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: var(--primary);
      margin-bottom: 16px;
      display: block;
    }

    .section-title {
      font-family: var(--font-heading);
      font-size: clamp(28px, 5vw, 42px);
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 20px;
      color: var(--text-dark);
    }

    .section-subtitle {
      font-size: 18px;
      color: var(--text-secondary);
      max-width: 600px;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 16px 32px;
      background: var(--primary);
      color: var(--secondary);
      font-family: var(--font-heading);
      font-size: 16px;
      font-weight: 700;
      text-decoration: none;
      border-radius: var(--radius-md);
      border: none;
      cursor: pointer;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .btn-primary:hover {
      transform: translateY(-3px) scale(1.02);
      box-shadow: 0 12px 30px rgba(0, 212, 255, 0.45), 0 0 0 4px rgba(0, 212, 255, 0.15);
    }

    .btn-primary.btn-shimmer::after {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 60%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
      animation: shimmer 3s infinite;
    }

    @keyframes shimmer {
      0% { left: -100%; }
      100% { left: 200%; }
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 16px 32px;
      background: transparent;
      color: var(--text-dark);
      font-family: var(--font-heading);
      font-size: 16px;
      font-weight: 600;
      text-decoration: none;
      border-radius: var(--radius-md);
      border: 2px solid var(--border-light);
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .btn-secondary:hover {
      border-color: var(--primary);
      color: var(--primary);
    }

    .fade-in {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }

    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Placeholder Images */
    .img-placeholder {
      position: relative;
      overflow: hidden;
      background: linear-gradient(135deg, var(--secondary) 0%, var(--neutral-dark) 100%);
      border: 1px solid rgba(0, 212, 255, 0.1);
      border-radius: var(--radius-lg);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 12px;
    }

    .ph-icon {
      width: 48px;
      height: 48px;
      color: var(--primary);
      opacity: 0.6;
    }

    .ph-label {
      font-family: var(--font-accent);
      font-size: 12px;
      color: rgba(255,255,255,0.6);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .ph-size {
      font-family: var(--font-accent);
      font-size: 11px;
      color: rgba(255,255,255,0.4);
    }

    /* ==================== HEADER ==================== */
    .header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      backdrop-filter: blur(20px);
      background: rgba(255, 255, 255, 0.85);
      border-bottom: 1px solid rgba(0, 212, 255, 0.08);
      transition: all 0.3s ease;
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
    }

    .logo {
      display: flex;
      align-items: center;
      text-decoration: none;
    }

    .logo img {
      height: 40px;
      width: auto;
      object-fit: contain;
    }

    .nav-desktop {
      display: flex;
      align-items: center;
      gap: 32px;
    }

    .nav-link {
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 500;
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .nav-link:hover {
      color: var(--primary);
    }

    .header-cta {
      padding: 12px 24px;
      font-size: 14px;
    }

    .hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 32px;
      height: 32px;
      background: none;
      border: none;
      cursor: pointer;
      z-index: 110;
    }

    .hamburger span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--text-dark);
      transition: all 0.3s ease;
    }

    .hamburger.active span:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
    }

    .hamburger.active span:nth-child(2) {
      opacity: 0;
    }

    .hamburger.active span:nth-child(3) {
      transform: rotate(-45deg) translate(5px, -5px);
    }

    @media (max-width: 768px) {
      .nav-desktop {
        display: none;
      }

      .hamburger {
        display: flex;
      }

      .header-cta {
        display: none;
      }
    }

    /* ==================== MOBILE MENU ==================== */
    .mobile-menu {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--bg-white);
      z-index: 105;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 32px;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
    }

    .mobile-menu.open {
      opacity: 1;
      visibility: visible;
    }

    .mobile-link {
      font-family: var(--font-heading);
      font-size: 24px;
      font-weight: 700;
      color: var(--text-dark);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .mobile-link:hover {
      color: var(--primary);
    }

    .mobile-cta {
      margin-top: 20px;
    }

    /* ==================== HERO ==================== */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 120px 0 80px;
      background: linear-gradient(135deg, rgba(0, 212, 255, 0.03) 0%, #FFF 50%, rgba(10, 22, 40, 0.02) 100%);
      overflow: hidden;
    }

    .hero-glow {
      position: absolute;
      width: 800px;
      height: 800px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(0, 212, 255, 0.15) 0%, transparent 70%);
      animation: glow-pulse 4s ease-in-out infinite alternate;
      pointer-events: none;
    }

    .hero-glow-1 {
      top: -200px;
      right: -200px;
    }

    .hero-glow-2 {
      bottom: -300px;
      left: -300px;
      background: radial-gradient(circle, rgba(255, 107, 53, 0.08) 0%, transparent 70%);
      animation-delay: 2s;
    }

    @keyframes glow-pulse {
      0% { transform: scale(1); opacity: 0.5; }
      100% { transform: scale(1.1); opacity: 0.8; }
    }

    /* Hero Background Animation - Scanning waves */
    .hero-bg-animation {
      position: absolute;
      top: 50%;
      right: 5%;
      transform: translateY(-50%);
      width: 500px;
      height: 500px;
      pointer-events: none;
      z-index: 0;
    }

    .scan-wave {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      border: 1px solid rgba(0, 212, 255, 0.15);
      animation: scan-pulse 4s ease-out infinite;
    }

    .scan-wave-1 { width: 150px; height: 150px; }
    .scan-wave-2 { width: 250px; height: 250px; animation-delay: 0.8s; }
    .scan-wave-3 { width: 350px; height: 350px; animation-delay: 1.6s; }
    .scan-wave-4 { width: 450px; height: 450px; animation-delay: 2.4s; }

    @keyframes scan-pulse {
      0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
      100% { transform: translate(-50%, -50%) scale(1.2); opacity: 0; }
    }

    .scan-line {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 200px;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--primary), transparent);
      transform-origin: left center;
      animation: scan-rotate 6s linear infinite;
    }

    @keyframes scan-rotate {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    /* Floating Tech Decorations */
    .floating-decoration {
      position: absolute;
      font-size: 32px;
      opacity: 0.15;
      animation: float 6s ease-in-out infinite;
      pointer-events: none;
      z-index: 0;
    }

    .floating-decoration:nth-child(1) { top: 15%; left: 8%; animation-delay: 0s; }
    .floating-decoration:nth-child(2) { top: 25%; right: 12%; animation-delay: 1s; font-size: 28px; }
    .floating-decoration:nth-child(3) { top: 60%; left: 5%; animation-delay: 2s; font-size: 24px; }
    .floating-decoration:nth-child(4) { bottom: 20%; right: 8%; animation-delay: 3s; }
    .floating-decoration:nth-child(5) { top: 40%; left: 15%; animation-delay: 4s; font-size: 20px; }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-15px) rotate(5deg); }
    }

    /* Hero Product Glow Ring */
    .hero-image-wrapper {
      position: relative;
    }

    .hero-image-ring {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 110%;
      height: 110%;
      transform: translate(-50%, -50%);
      border: 2px dashed rgba(0, 212, 255, 0.3);
      border-radius: var(--radius-xl);
      animation: ring-rotate 20s linear infinite;
      pointer-events: none;
    }

    .hero-image-glow {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 90%;
      height: 90%;
      transform: translate(-50%, -50%);
      background: radial-gradient(circle, rgba(0, 212, 255, 0.15) 0%, transparent 70%);
      border-radius: var(--radius-xl);
      animation: glow-pulse 3s ease-in-out infinite;
      pointer-events: none;
      z-index: -1;
    }

    @keyframes ring-rotate {
      0% { transform: translate(-50%, -50%) rotate(0deg); }
      100% { transform: translate(-50%, -50%) rotate(360deg); }
    }

    @media (max-width: 768px) {
      .floating-decoration {
        display: none;
      }
      .hero-image-ring,
      .hero-image-glow {
        display: none;
      }
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }

    .hero-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 24px;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      background: var(--primary-soft);
      border: 1px solid rgba(0, 212, 255, 0.2);
      border-radius: 50px;
      font-family: var(--font-accent);
      font-size: 12px;
      font-weight: 500;
      color: var(--primary);
    }

    .hero-badge svg {
      width: 14px;
      height: 14px;
    }

    .hero-title {
      font-family: var(--font-heading);
      font-size: clamp(36px, 6vw, 56px);
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: 24px;
      color: var(--text-dark);
    }

    .hero-title span {
      color: var(--primary);
    }

    .hero-subtitle {
      font-size: 18px;
      color: var(--text-secondary);
      margin-bottom: 32px;
      max-width: 500px;
      line-height: 1.7;
    }

    .hero-ctas {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      margin-bottom: 40px;
    }

    .hero-stats {
      display: flex;
      gap: 40px;
    }

    .hero-stat {
      text-align: left;
    }

    .hero-stat-value {
      font-family: var(--font-heading);
      font-size: 36px;
      font-weight: 700;
      line-height: 1;
      background: linear-gradient(135deg, var(--primary) 0%, #5CE3FF 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: -0.02em;
    }

    /* Floating feature badges around hero product */
    .hero-feature-badge {
      position: absolute;
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      background: var(--bg-white);
      border: 1px solid rgba(0, 212, 255, 0.3);
      border-radius: 50px;
      box-shadow: 0 12px 32px rgba(0, 212, 255, 0.15);
      font-family: var(--font-accent);
      font-size: 11px;
      font-weight: 500;
      color: var(--secondary);
      white-space: nowrap;
      z-index: 3;
      animation: badgeFloat 4s ease-in-out infinite;
    }

    .hero-feature-badge::before {
      content: '';
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--primary);
      box-shadow: 0 0 10px var(--primary);
    }

    .hero-feature-badge.hfb-1 { top: 8%; left: -8%; animation-delay: 0s; }
    .hero-feature-badge.hfb-2 { top: 28%; right: -10%; animation-delay: 1s; }
    .hero-feature-badge.hfb-3 { bottom: 28%; left: -12%; animation-delay: 2s; }
    .hero-feature-badge.hfb-4 { bottom: 6%; right: -6%; animation-delay: 3s; }

    .hero-feature-badge.hfb-3::before,
    .hero-feature-badge.hfb-4::before {
      background: var(--accent);
      box-shadow: 0 0 10px var(--accent);
    }

    @keyframes badgeFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    @media (max-width: 968px) {
      .hero-feature-badge { display: none; }
    }

    .hero-stat-label {
      font-size: 13px;
      color: var(--text-secondary);
    }

    .hero-visual {
      position: relative;
    }

    .hero-image {
      position: relative;
      z-index: 1;
    }

    @media (max-width: 968px) {
      .hero-grid {
        grid-template-columns: 1fr;
        text-align: center;
      }

      .hero-badges {
        justify-content: center;
      }

      .hero-subtitle {
        margin-left: auto;
        margin-right: auto;
      }

      .hero-ctas {
        justify-content: center;
      }

      .hero-stats {
        justify-content: center;
      }

      .hero-visual {
        order: -1;
        max-width: 500px;
        margin: 0 auto;
      }

      .hero-bg-animation {
        display: none;
      }
    }

    /* ==================== WAVY DIVIDERS ==================== */
    .wavy-divider {
      position: relative;
      margin-top: -1px;
      height: 60px;
      overflow: hidden;
    }

    .wavy-divider svg {
      position: absolute;
      bottom: 0;
      width: 100%;
      height: 100%;
    }

    .wavy-divider.flip svg {
      transform: scaleY(-1);
    }

    /* ==================== TRUST BAR ==================== */
    .trust-bar {
      padding: 32px 0;
      background: linear-gradient(90deg, rgba(0, 212, 255, 0.04) 0%, rgba(10, 22, 40, 0.04) 100%);
      border-top: 1px solid rgba(0, 212, 255, 0.1);
      border-bottom: 1px solid rgba(0, 212, 255, 0.1);
    }

    .trust-items {
      display: flex;
      justify-content: center;
      gap: 20px;
      flex-wrap: nowrap;
    }

    .trust-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 16px;
      background: var(--bg-white);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-md);
      transition: all 0.3s ease;
      flex-shrink: 0;
    }

    .trust-item:hover {
      border-color: var(--primary);
      box-shadow: 0 4px 12px rgba(0, 212, 255, 0.15);
    }

    .trust-icon {
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--primary-soft);
      border-radius: var(--radius-sm);
      flex-shrink: 0;
    }

    .trust-icon svg {
      width: 20px;
      height: 20px;
      color: var(--primary);
    }

    .trust-text {
      white-space: nowrap;
    }

    .trust-text strong {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-dark);
    }

    .trust-text span {
      font-size: 12px;
      color: var(--text-secondary);
    }

    @media (max-width: 768px) {
      .trust-items {
        flex-wrap: wrap;
        gap: 12px;
      }

      .trust-item {
        flex: 1 1 calc(50% - 6px);
        min-width: 150px;
      }
    }

    /* ==================== PRODUCT GALLERY ==================== */
    .product-gallery {
      padding: 100px 0;
      background: var(--bg-white);
    }

    .gallery-header {
      text-align: center;
      margin-bottom: 50px;
    }

    .gallery-header .section-subtitle {
      margin: 0 auto;
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      grid-template-rows: 1fr 1fr;
      gap: 20px;
      max-width: 1000px;
      margin: 0 auto;
    }

    .gallery-item {
      position: relative;
      border-radius: var(--radius-xl);
      overflow: hidden;
      cursor: pointer;
      transition: all 0.4s ease;
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .gallery-item:hover img {
      transform: scale(1.05);
    }

    .gallery-item:hover {
      box-shadow: var(--shadow-xl);
    }

    .gallery-main {
      grid-row: span 2;
    }

    .gallery-item-label {
      position: absolute;
      bottom: 16px;
      left: 16px;
      padding: 8px 16px;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(8px);
      border-radius: 50px;
      font-family: var(--font-accent);
      font-size: 12px;
      font-weight: 500;
      color: var(--text-dark);
      opacity: 0;
      transform: translateY(10px);
      transition: all 0.3s ease;
    }

    .gallery-item:hover .gallery-item-label {
      opacity: 1;
      transform: translateY(0);
    }

    .gallery-zoom-hint {
      position: absolute;
      top: 16px;
      right: 16px;
      width: 40px;
      height: 40px;
      background: rgba(255, 255, 255, 0.9);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .gallery-zoom-hint svg {
      width: 20px;
      height: 20px;
      color: var(--text-dark);
    }

    .gallery-item:hover .gallery-zoom-hint {
      opacity: 1;
    }

    @media (max-width: 768px) {
      .gallery-grid {
        grid-template-columns: 1fr;
        grid-template-rows: auto;
      }

      .gallery-main {
        grid-row: auto;
        aspect-ratio: 4/3;
      }

      .gallery-item:not(.gallery-main) {
        aspect-ratio: 16/9;
      }
    }

    /* ==================== PROBLEM SECTION ==================== */
    .problem {
      padding: 100px 0;
      background: linear-gradient(180deg, #FFFBF8 0%, #FFF5F0 100%);
    }

    .problem-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }

    .problem-content {
      max-width: 520px;
    }

    .problem-title {
      font-family: var(--font-heading);
      font-size: clamp(28px, 4vw, 38px);
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 24px;
      color: var(--text-dark);
    }

    .problem-text {
      font-size: 16px;
      color: var(--text-secondary);
      margin-bottom: 32px;
      line-height: 1.8;
    }

    .problem-stats {
      display: flex;
      gap: 24px;
    }

    .problem-stat {
      padding: 24px;
      background: var(--bg-white);
      border-radius: var(--radius-md);
      border: 1px solid var(--border-light);
      box-shadow: var(--shadow-md);
      transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
      position: relative;
    }

    .problem-stat::before {
      content: '';
      position: absolute;
      top: 12px;
      left: 12px;
      width: 14px;
      height: 14px;
      border-top: 2px solid var(--accent);
      border-left: 2px solid var(--accent);
      opacity: 0.5;
    }

    .problem-stat:hover {
      transform: translateY(-4px) rotate(-0.5deg);
      box-shadow: 8px 8px 0 rgba(255, 107, 53, 0.15), 0 12px 32px rgba(10, 22, 40, 0.08);
      border-color: var(--accent);
    }

    .problem-stat-value {
      font-family: var(--font-heading);
      font-size: 44px;
      font-weight: 700;
      line-height: 1;
      background: linear-gradient(135deg, var(--accent) 0%, #FF9060 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: -0.02em;
    }

    .problem-stat-label {
      font-size: 13px;
      color: var(--text-secondary);
      margin-top: 4px;
    }

    .problem-visual {
      position: relative;
    }

    @media (max-width: 768px) {
      .problem-grid {
        grid-template-columns: 1fr;
      }

      .problem-visual {
        order: -1;
      }

      .problem-stats {
        flex-direction: column;
      }
    }

    /* ==================== SOLUTION / BENTO ==================== */
    .solution {
      padding: 100px 0;
      background: linear-gradient(180deg, var(--bg-white) 0%, rgba(10, 22, 40, 0.03) 100%);
    }

    .solution-header {
      text-align: center;
      margin-bottom: 60px;
    }

    .solution-header .section-subtitle {
      margin: 0 auto;
    }

    .bento-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: minmax(360px, auto);
      gap: 24px;
    }

    .bento-card:nth-child(1) {
      grid-column: span 2;
    }

    .bento-card:nth-child(4) {
      grid-column: span 2;
    }

    .bento-card {
      position: relative;
      padding: 32px;
      background: var(--bg-white);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-xl);
      overflow: hidden;
      transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .bento-card::before,
    .bento-card::after {
      content: '';
      position: absolute;
      width: 16px;
      height: 16px;
      pointer-events: none;
      opacity: 0.6;
      transition: opacity 0.3s ease;
    }

    .bento-card::before {
      top: 14px;
      left: 14px;
      border-top: 2px solid var(--primary);
      border-left: 2px solid var(--primary);
    }

    .bento-card::after {
      bottom: 14px;
      right: 14px;
      border-bottom: 2px solid var(--primary);
      border-right: 2px solid var(--primary);
    }

    .bento-card:hover::before,
    .bento-card:hover::after {
      opacity: 1;
    }

    .bento-card:hover {
      border-color: var(--primary);
      box-shadow: 0 16px 40px rgba(0, 212, 255, 0.2), 8px 8px 0 rgba(0, 212, 255, 0.1);
      transform: translateY(-6px) rotate(-0.5deg);
    }

    /* Staggered animation */
    .bento-card:nth-child(1) { animation-delay: 0ms; }
    .bento-card:nth-child(2) { animation-delay: 100ms; }
    .bento-card:nth-child(3) { animation-delay: 200ms; }
    .bento-card:nth-child(4) { animation-delay: 300ms; }

    .bento-card:nth-child(2):hover {
      border-color: var(--secondary);
    }

    .bento-card:nth-child(3):hover {
      border-color: var(--accent);
    }

    .bento-card:nth-child(4):hover {
      border-color: var(--primary);
    }

    .spotlight {
      position: absolute;
      width: 300px;
      height: 300px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(0, 212, 255, 0.08) 0%, transparent 70%);
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.4s ease;
      transform: translate(-50%, -50%);
    }

    .bento-card:hover .spotlight {
      opacity: 1;
    }

    .bento-card:nth-child(2) .spotlight {
      background: radial-gradient(circle, rgba(10, 22, 40, 0.08) 0%, transparent 70%);
    }

    .bento-card:nth-child(3) .spotlight {
      background: radial-gradient(circle, rgba(255, 107, 53, 0.08) 0%, transparent 70%);
    }

    .bento-image {
      margin-bottom: 20px;
    }

    .bento-icon {
      width: 56px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--primary-soft);
      border-radius: var(--radius-md);
      margin-bottom: 20px;
    }

    .bento-icon svg {
      width: 28px;
      height: 28px;
      color: var(--primary);
    }

    .bento-card:nth-child(2) .bento-icon {
      background: rgba(10, 22, 40, 0.08);
    }

    .bento-card:nth-child(2) .bento-icon svg {
      color: var(--secondary);
    }

    .bento-card:nth-child(3) .bento-icon {
      background: rgba(255, 107, 53, 0.1);
    }

    .bento-card:nth-child(3) .bento-icon svg {
      color: var(--accent);
    }

    .bento-title {
      font-family: var(--font-heading);
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 12px;
      color: var(--text-dark);
    }

    .bento-text {
      font-size: 15px;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    @media (max-width: 968px) {
      .bento-grid {
        grid-template-columns: 1fr;
        grid-auto-rows: auto;
      }
      .bento-card:nth-child(1),
      .bento-card:nth-child(4) {
        grid-column: span 1;
      }
    }

    /* ==================== TECHNOLOGY ==================== */
    .technology {
      padding: 100px 0;
      background: linear-gradient(180deg, var(--secondary) 0%, #0D2137 100%);
      color: #FFFFFF;
      position: relative;
      overflow: hidden;
    }

    .technology::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background:
        radial-gradient(circle at 20% 50%, rgba(0, 212, 255, 0.1) 0%, transparent 50%),
        radial-gradient(circle at 80% 30%, rgba(0, 212, 255, 0.08) 0%, transparent 40%);
      pointer-events: none;
    }

    .technology .container {
      position: relative;
      z-index: 1;
    }

    .tech-header {
      text-align: center;
      margin-bottom: 60px;
    }

    .tech-header .section-label {
      color: var(--primary);
    }

    .tech-header .section-title {
      color: #FFFFFF;
    }

    .tech-header .section-subtitle {
      color: rgba(255, 255, 255, 0.7);
      margin: 0 auto;
    }

    .tech-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }

    .tech-visual {
      position: relative;
    }

    .tech-visual img {
      width: 100%;
      border-radius: var(--radius-xl);
      box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
    }

    .tech-features {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .tech-feature {
      display: flex;
      gap: 20px;
      padding: 24px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(0, 212, 255, 0.15);
      border-radius: var(--radius-lg);
      transition: all 0.3s ease;
    }

    .tech-feature:hover {
      background: rgba(0, 212, 255, 0.1);
      border-color: var(--primary);
      transform: translateX(8px);
    }

    .tech-feature-icon {
      width: 56px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0, 212, 255, 0.15);
      border-radius: var(--radius-md);
      flex-shrink: 0;
    }

    .tech-feature-icon svg {
      width: 28px;
      height: 28px;
      color: var(--primary);
    }

    .tech-feature-content h4 {
      font-family: var(--font-heading);
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 8px;
      color: #FFFFFF;
    }

    .tech-feature-content p {
      font-size: 14px;
      color: rgba(255, 255, 255, 0.7);
      line-height: 1.6;
    }

    .tech-specs {
      display: flex;
      gap: 32px;
      margin-top: 40px;
      padding-top: 32px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .tech-spec {
      text-align: center;
    }

    .tech-spec-value {
      font-family: var(--font-heading);
      font-size: 28px;
      font-weight: 700;
      color: var(--primary);
    }

    .tech-spec-label {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.6);
      margin-top: 4px;
    }

    @media (max-width: 768px) {
      .tech-grid {
        grid-template-columns: 1fr;
        gap: 40px;
      }

      .tech-visual {
        order: -1;
      }

      .tech-specs {
        flex-wrap: wrap;
        justify-content: center;
      }

      .tech-spec {
        flex: 1 1 45%;
      }
    }

    /* ==================== HOW IT WORKS ==================== */
    .how-it-works {
      padding: 100px 0;
      background: linear-gradient(180deg, #FFF8E7 0%, #FFFDF5 100%);
    }

    .how-header {
      text-align: center;
      margin-bottom: 60px;
    }

    .how-header .section-subtitle {
      margin: 0 auto;
    }

    .how-steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }

    .how-step {
      text-align: center;
    }

    .how-step-image {
      margin-bottom: 24px;
    }

    .how-step-number {
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
      background: var(--primary);
      border-radius: 50%;
      font-family: var(--font-heading);
      font-size: 20px;
      font-weight: 700;
      color: var(--secondary);
    }

    .how-step:nth-child(2) .how-step-number {
      background: var(--secondary);
      color: var(--bg-white);
    }

    .how-step:nth-child(3) .how-step-number {
      background: #22C55E;
      color: var(--bg-white);
    }

    .how-step-title {
      font-family: var(--font-heading);
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 12px;
      color: var(--text-dark);
    }

    .how-step-text {
      font-size: 15px;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    @media (max-width: 768px) {
      .how-steps {
        grid-template-columns: 1fr;
        max-width: 400px;
        margin: 0 auto;
      }
    }

    /* ==================== PERSONAS ==================== */
    .personas {
      padding: 100px 0;
      background: linear-gradient(180deg, var(--bg-white) 0%, rgba(0, 212, 255, 0.03) 100%);
    }

    .personas-header {
      text-align: center;
      margin-bottom: 60px;
    }

    .personas-header .section-subtitle {
      margin: 0 auto;
    }

    .personas-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }

    .persona-card {
      padding: 32px;
      background: var(--bg-white);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-xl);
      text-align: center;
      transition: all 0.4s ease;
      position: relative;
      overflow: hidden;
    }

    .persona-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--primary), var(--secondary));
      transform: scaleX(0);
      transition: transform 0.4s ease;
    }

    .persona-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0, 212, 255, 0.15);
      border-color: var(--primary);
    }

    .persona-card:hover::before {
      transform: scaleX(1);
    }

    .persona-icon {
      width: 80px;
      height: 80px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 24px;
      background: var(--primary-soft);
      border-radius: 50%;
      font-size: 36px;
    }

    .persona-card:nth-child(2) .persona-icon {
      background: rgba(10, 22, 40, 0.08);
    }

    .persona-card:nth-child(3) .persona-icon {
      background: rgba(255, 107, 53, 0.1);
    }

    .persona-title {
      font-family: var(--font-heading);
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 12px;
      color: var(--text-dark);
    }

    .persona-text {
      font-size: 15px;
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 20px;
    }

    .persona-usecases {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: center;
    }

    .persona-usecase {
      padding: 6px 12px;
      background: var(--secondary-soft);
      border-radius: 50px;
      font-family: var(--font-accent);
      font-size: 11px;
      color: var(--text-secondary);
    }

    @media (max-width: 768px) {
      .personas-grid {
        grid-template-columns: 1fr;
        max-width: 400px;
        margin: 0 auto;
      }
    }

    /* ==================== COMPARISON ==================== */
    .comparison {
      padding: 100px 0;
      background: linear-gradient(180deg, rgba(10, 22, 40, 0.03) 0%, var(--bg-white) 100%);
    }

    .comparison-header {
      text-align: center;
      margin-bottom: 60px;
    }

    .comparison-header .section-subtitle {
      margin: 0 auto;
    }

    .comparison-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      max-width: 900px;
      margin: 0 auto;
    }

    .comparison-card {
      padding: 40px;
      border-radius: var(--radius-xl);
      background: var(--bg-white);
      box-shadow: var(--shadow-md);
    }

    .comparison-card.highlight {
      border: 2px solid var(--primary);
      box-shadow: var(--shadow-lg);
      position: relative;
    }

    .comparison-card.highlight::before {
      content: 'Polecane';
      position: absolute;
      top: -12px;
      left: 50%;
      transform: translateX(-50%);
      padding: 6px 16px;
      background: var(--primary);
      color: var(--secondary);
      font-family: var(--font-accent);
      font-size: 11px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 1px;
      border-radius: 50px;
    }

    .comparison-card h3 {
      font-family: var(--font-heading);
      font-size: 22px;
      font-weight: 700;
      margin-bottom: 16px;
      color: var(--text-dark);
    }

    .comparison-desc {
      font-size: 14px;
      color: var(--text-secondary);
      margin-bottom: 24px;
      line-height: 1.7;
    }

    .comparison-card ul {
      list-style: none;
    }

    .comparison-card ul li {
      padding: 12px 16px;
      margin-bottom: 8px;
      background: rgba(0, 0, 0, 0.02);
      border-radius: var(--radius-sm);
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.6;
      position: relative;
      padding-left: 36px;
    }

    .comparison-card ul li::before {
      content: '—';
      position: absolute;
      left: 12px;
      color: var(--neutral-mid);
      font-weight: 600;
    }

    .comparison-card ul li:last-child {
      margin-bottom: 0;
    }

    .comparison-card.highlight ul li {
      color: var(--text-dark);
      background: rgba(0, 212, 255, 0.06);
    }

    .comparison-card.highlight ul li::before {
      content: '+';
      color: var(--primary);
      font-size: 16px;
    }

    @media (max-width: 768px) {
      .comparison-grid {
        grid-template-columns: 1fr;
      }
    }


    /* ==================== FAQ ==================== */
    .faq {
      padding: 100px 0;
      background: linear-gradient(180deg, rgba(10, 22, 40, 0.03) 0%, var(--bg-white) 100%);
    }

    .faq-header {
      text-align: center;
      margin-bottom: 60px;
    }

    .faq-header .section-subtitle {
      margin: 0 auto;
    }

    .faq-list {
      max-width: 800px;
      margin: 0 auto;
    }

    .faq-item {
      margin-bottom: 16px;
      border: 1px solid var(--border-light);
      border-radius: var(--radius-md);
      overflow: hidden;
      background: var(--bg-white);
    }

    .faq-question {
      width: 100%;
      padding: 20px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: none;
      border: none;
      cursor: pointer;
      text-align: left;
      transition: all 0.3s ease;
    }

    .faq-question:hover {
      background: var(--bg-alt);
    }

    .faq-question span {
      font-family: var(--font-heading);
      font-size: 16px;
      font-weight: 600;
      color: var(--text-dark);
      padding-right: 20px;
    }

    .faq-question svg {
      width: 20px;
      height: 20px;
      color: var(--primary);
      flex-shrink: 0;
      transition: transform 0.3s ease;
    }

    .faq-item.active .faq-question svg {
      transform: rotate(180deg);
    }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }

    .faq-item.active .faq-answer {
      max-height: 500px;
    }

    .faq-answer-inner {
      padding: 0 24px 24px;
      font-size: 15px;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    /* ==================== OFFER ==================== */
    .offer {
      padding: 100px 0;
      background: linear-gradient(135deg, rgba(0, 212, 255, 0.05) 0%, var(--bg-white) 50%, rgba(10, 22, 40, 0.03) 100%);
    }

    .offer-header {
      text-align: center;
      margin-bottom: 60px;
    }

    .offer-header .section-subtitle {
      margin: 0 auto;
    }

    .offer-box {
      max-width: 700px;
      margin: 0 auto;
      padding: 48px;
      background: var(--bg-white);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-xl);
      position: relative;
      overflow: hidden;
    }

    .offer-box::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--primary), var(--accent), var(--primary));
      background-size: 200% 100%;
      animation: border-beam 3s linear infinite;
    }

    @keyframes border-beam {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }

    .offer-badge {
      display: inline-block;
      padding: 8px 20px;
      background: var(--accent);
      color: white;
      font-family: var(--font-accent);
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 1px;
      border-radius: 50px;
      margin-bottom: 24px;
    }

    .offer-image {
      margin: 24px 0;
    }

    .offer-title {
      font-family: var(--font-heading);
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 8px;
      color: var(--text-dark);
    }

    .offer-subtitle {
      font-size: 16px;
      color: var(--text-secondary);
      margin-bottom: 24px;
    }

    .offer-price {
      margin-bottom: 32px;
    }

    .offer-price-old {
      font-size: 18px;
      color: var(--text-secondary);
      text-decoration: line-through;
      margin-right: 12px;
    }

    .offer-price-new {
      font-family: var(--font-heading);
      font-size: 48px;
      font-weight: 700;
      color: var(--primary);
    }

    .offer-price-new span {
      font-size: 24px;
    }

    .offer-urgency {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      background: linear-gradient(90deg, rgba(255, 107, 53, 0.1), rgba(255, 107, 53, 0.05));
      border: 1px solid rgba(255, 107, 53, 0.2);
      border-radius: 50px;
      margin-bottom: 20px;
      animation: urgency-pulse 2s ease-in-out infinite;
    }

    .offer-urgency svg {
      width: 18px;
      height: 18px;
      color: var(--accent);
    }

    .offer-urgency span {
      font-family: var(--font-accent);
      font-size: 13px;
      font-weight: 500;
      color: var(--accent);
    }

    @keyframes urgency-pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.02); }
    }

    .offer-savings {
      display: inline-block;
      padding: 6px 12px;
      background: rgba(34, 197, 94, 0.1);
      color: #22C55E;
      font-size: 13px;
      font-weight: 600;
      border-radius: var(--radius-sm);
      margin-top: 8px;
    }

    .offer-includes {
      text-align: left;
      margin-bottom: 32px;
      padding: 24px;
      background: var(--bg-alt);
      border-radius: var(--radius-md);
    }

    .offer-includes h4 {
      font-family: var(--font-heading);
      font-size: 14px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-dark);
      margin-bottom: 16px;
    }

    .offer-includes ul {
      list-style: none;
    }

    .offer-includes ul li {
      padding: 8px 0;
      font-size: 15px;
      color: var(--text-dark);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .offer-includes ul li svg {
      width: 18px;
      height: 18px;
      color: var(--primary);
      flex-shrink: 0;
    }

    .offer-cta {
      width: 100%;
      padding: 20px 40px;
      font-size: 18px;
      animation: pulse-glow 2s ease-in-out infinite;
    }

    @keyframes pulse-glow {
      0%, 100% { box-shadow: 0 0 0 0 rgba(0, 212, 255, 0.4); }
      50% { box-shadow: 0 0 0 12px rgba(0, 212, 255, 0); }
    }

    .offer-guarantee {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 20px;
      font-size: 13px;
      color: var(--text-secondary);
    }

    .offer-guarantee svg {
      width: 18px;
      height: 18px;
      color: #22C55E;
    }

    @media (max-width: 768px) {
      .offer-box {
        padding: 32px 24px;
      }

      .offer-price-new {
        font-size: 36px;
      }
    }

    /* ==================== CTA BANNER ==================== */
    .cta-banner {
      padding: 100px 0;
      background: linear-gradient(135deg, var(--secondary) 0%, #0D2137 50%, var(--secondary) 100%);
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .cta-banner::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at 30% 50%, rgba(0, 212, 255, 0.15) 0%, transparent 50%),
                  radial-gradient(circle at 70% 50%, rgba(0, 212, 255, 0.1) 0%, transparent 50%);
      pointer-events: none;
    }

    .cta-banner .container {
      position: relative;
      z-index: 1;
    }

    .cta-title {
      font-family: var(--font-heading);
      font-size: clamp(32px, 6vw, 48px);
      font-weight: 700;
      color: #FFFFFF;
      margin-bottom: 16px;
    }

    .cta-subtitle {
      font-size: 18px;
      color: rgba(255, 255, 255, 0.75);
      margin-bottom: 40px;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
    }

    .cta-banner .btn-primary {
      background: var(--primary);
      color: var(--secondary);
      padding: 18px 40px;
      font-size: 18px;
    }

    .cta-banner .btn-primary:hover {
      box-shadow: 0 12px 35px rgba(0, 212, 255, 0.5), 0 0 0 4px rgba(0, 212, 255, 0.2);
      transform: translateY(-3px) scale(1.02);
    }

    /* ==================== FOOTER ==================== */
    .footer {
      padding: 60px 0 30px;
      background: #FAFAFA;
      border-top: 2px solid transparent;
      border-image: linear-gradient(90deg, var(--primary), var(--secondary)) 1;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 60px;
      margin-bottom: 40px;
    }

    .footer-brand .logo {
      margin-bottom: 16px;
    }

    .footer-brand p {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.7;
      max-width: 300px;
    }

    .footer-links h4,
    .footer-contact h4 {
      font-family: var(--font-heading);
      font-size: 14px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-dark);
      margin-bottom: 20px;
    }

    .footer-links ul {
      list-style: none;
    }

    .footer-links ul li {
      margin-bottom: 12px;
    }

    .footer-links ul li a {
      font-size: 14px;
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .footer-links ul li a:hover {
      color: var(--primary);
    }

    .footer-contact p {
      font-size: 14px;
      color: var(--text-secondary);
      margin-bottom: 8px;
    }

    .footer-contact a {
      color: var(--primary);
      text-decoration: none;
    }

    .footer-bottom {
      padding-top: 30px;
      border-top: 1px solid var(--border-light);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }

    .footer-bottom p {
      font-size: 13px;
      color: var(--text-secondary);
    }

    .footer-legal {
      display: flex;
      gap: 24px;
    }

    .footer-legal a {
      font-size: 13px;
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .footer-legal a:hover {
      color: var(--primary);
    }

    @media (max-width: 768px) {
      .footer-grid {
        grid-template-columns: 1fr;
        gap: 40px;
      }

      .footer-bottom {
        flex-direction: column;
        text-align: center;
      }
    }

    /* ==================== STICKY CTA (MOBILE) ==================== */
    .sticky-cta {
      display: none;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 16px 20px;
      background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.95) 20%, #fff 100%);
      z-index: 90;
      transform: translateY(100%);
      transition: transform 0.4s ease;
    }

    .sticky-cta.visible {
      transform: translateY(0);
    }

    .sticky-cta-inner {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .sticky-cta-price {
      flex: 1;
    }

    .sticky-cta-price .old {
      font-size: 12px;
      color: var(--text-secondary);
      text-decoration: line-through;
    }

    .sticky-cta-price .new {
      font-family: var(--font-heading);
      font-size: 20px;
      font-weight: 700;
      color: var(--primary);
    }

    .sticky-cta .btn-primary {
      flex: 1;
      padding: 14px 20px;
      font-size: 14px;
      animation: pulse-glow 2s ease-in-out infinite;
    }

    @media (max-width: 768px) {
      .sticky-cta {
        display: block;
      }
    }

    /* ==================== COOKIE BANNER ==================== */
    .cookie-banner {
      position: fixed;
      bottom: -200px;
      left: 24px;
      right: 24px;
      max-width: 500px;
      padding: 24px;
      background: var(--bg-white);
      border-radius: var(--radius-lg);
      box-shadow: 0 -4px 30px rgba(0,0,0,0.15);
      z-index: 200;
      transition: bottom 0.5s ease;
    }

    .cookie-banner.show {
      bottom: 24px;
    }

    .cookie-banner p {
      font-size: 14px;
      color: var(--text-secondary);
      margin-bottom: 16px;
      line-height: 1.6;
    }

    .cookie-banner a {
      color: var(--primary);
      text-decoration: none;
    }

    .cookie-buttons {
      display: flex;
      gap: 12px;
    }

    .cookie-accept {
      padding: 12px 24px;
      background: var(--primary);
      color: var(--secondary);
      font-family: var(--font-heading);
      font-size: 14px;
      font-weight: 600;
      border: none;
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .cookie-accept:hover {
      background: var(--secondary);
      color: var(--bg-white);
    }

    @media (max-width: 768px) {
      .cookie-banner {
        left: 16px;
        right: 16px;
      }
    }

    /* ═══ OPINIE — sekcja XL (template + chain fallback do tokenów innerscan: --text-dark/--bg-alt/--font-heading) ═══ */
    .reviews-xl {
      padding: var(--section-padding, 100px) 0;
      background: linear-gradient(180deg,
        var(--bg-cream, var(--bg-alt, #F8FAFC)) 0%,
        var(--bg-white, #FFFFFF) 50%,
        var(--primary-soft, rgba(0,212,255,0.08)) 100%);
      position: relative;
      overflow: hidden;
    }
    .reviews-xl::before {
      content: '';
      position: absolute;
      top: -120px; right: -120px;
      width: 360px; height: 360px;
      background: radial-gradient(circle, var(--primary-soft, rgba(0,212,255,0.08)) 0%, transparent 70%);
      pointer-events: none;
    }
    .reviews-xl::after {
      content: '';
      position: absolute;
      bottom: -120px; left: -120px;
      width: 360px; height: 360px;
      background: radial-gradient(circle, var(--secondary-soft, var(--accent-soft, rgba(255,107,53,0.08))) 0%, transparent 70%);
      pointer-events: none;
    }
    .reviews-xl .container { position: relative; z-index: 1; }
    .reviews-xl .reviews-header { text-align: center; max-width: 720px; margin: 0 auto 56px; }

    .reviews-grid-xl { column-count: 1; column-gap: 24px; }
    @media (min-width: 720px)  { .reviews-grid-xl { column-count: 2; } }
    @media (min-width: 1080px) { .reviews-grid-xl { column-count: 3; } }
    @media (min-width: 1440px) { .reviews-grid-xl { column-count: 4; } }

    .review-card {
      break-inside: avoid;
      background: var(--bg-white, #FFFFFF);
      border: 1px solid var(--border-light, rgba(15,23,42,0.06));
      border-radius: var(--radius-lg, 16px);
      overflow: hidden;
      margin-bottom: 24px;
      display: inline-block;
      width: 100%;
      box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,0.04));
      transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .review-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lg, 0 16px 48px rgba(0,212,255,0.12));
      border-color: var(--primary-soft, rgba(0,212,255,0.2));
    }

    .review-images {
      display: grid;
      gap: 2px;
      background: var(--border-light, rgba(15,23,42,0.06));
      grid-template-columns: repeat(2, 1fr);
    }
    .review-images[data-count="1"] { grid-template-columns: 1fr; }
    .review-images[data-count="3"] .review-img:first-child { grid-row: span 2; }
    .review-images .review-img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      cursor: zoom-in;
      transition: transform 0.4s ease, opacity 0.3s ease;
      display: block;
    }
    .review-images[data-count="3"] .review-img:first-child { aspect-ratio: 1; }
    .review-card:hover .review-images .review-img { transform: scale(1.03); }
    .review-images .review-img:hover { opacity: 0.92; }

    .review-body { padding: 24px 24px 18px; }
    .review-text {
      font-family: var(--font-body, system-ui);
      font-size: 14.5px;
      line-height: 1.65;
      color: var(--text-primary, var(--text-dark, #0D1117));
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 8;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .review-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px 22px 18px;
      border-top: 1px solid var(--border-light, rgba(15,23,42,0.06));
    }
    .review-author { display: flex; align-items: center; gap: 10px; min-width: 0; }
    .review-avatar {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: var(--gradient-cta, linear-gradient(135deg, var(--primary, #00D4FF), var(--secondary, var(--accent, #FF6B35))));
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,0.04));
    }
    .review-avatar svg { width: 16px; height: 16px; opacity: 0.95; }
    .review-tag {
      font-size: 11px;
      color: var(--text-tertiary, var(--text-secondary, rgba(15,23,42,0.5)));
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-weight: 500;
      letter-spacing: 0.01em;
    }
    .review-tag svg { width: 11px; height: 11px; opacity: 0.6; }
    .review-rating { display: flex; gap: 1px; color: #F59E0B; flex-shrink: 0; }
    .review-rating svg { width: 14px; height: 14px; }

    .reviews-empty-placeholder {
      text-align: center;
      padding: 80px 20px;
      color: var(--text-tertiary, rgba(15,23,42,0.4));
      font-family: var(--font-body, system-ui);
      font-size: 14px;
    }

    .reviews-disclosure-wrap { text-align: center; margin: 48px auto 0; position: relative; }
    .reviews-disclosure-trigger {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      background: transparent;
      border: 1px solid var(--border-light, rgba(15,23,42,0.08));
      border-radius: 999px;
      color: var(--text-tertiary, var(--text-secondary, rgba(15,23,42,0.5)));
      font-family: var(--font-body, system-ui);
      font-size: 12px;
      cursor: pointer;
      transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
      user-select: none;
    }
    .reviews-disclosure-trigger:hover {
      background: var(--primary-soft, rgba(0,212,255,0.08));
      color: var(--text-secondary, rgba(15,23,42,0.7));
      border-color: var(--primary, #00D4FF);
    }
    .reviews-disclosure-trigger svg { width: 14px; height: 14px; opacity: 0.7; }
    .reviews-disclosure-popover {
      display: none;
      position: relative;
      max-width: 600px;
      margin: 16px auto 0;
      padding: 18px 24px;
      background: var(--bg-white, #FFFFFF);
      border: 1px solid var(--border-light, rgba(15,23,42,0.06));
      border-radius: var(--radius-md, 12px);
      box-shadow: var(--shadow-md, 0 4px 16px rgba(0,0,0,0.08));
      text-align: left;
      font-family: var(--font-body, system-ui);
      font-size: 12.5px;
      line-height: 1.6;
      color: var(--text-secondary, rgba(15,23,42,0.7));
      animation: rev-pop-in 0.2s ease;
    }
    .reviews-disclosure-popover.show { display: block; }
    @keyframes rev-pop-in {
      from { opacity: 0; transform: translateY(-4px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .reviews-disclosure-popover strong { color: var(--text-primary, var(--text-dark, #0D1117)); font-weight: 600; }
    .reviews-disclosure-popover::before {
      content: '';
      position: absolute;
      top: -8px;
      left: 50%;
      transform: translateX(-50%);
      width: 14px;
      height: 14px;
      background: var(--bg-white, #FFFFFF);
      border-top: 1px solid var(--border-light, rgba(15,23,42,0.06));
      border-left: 1px solid var(--border-light, rgba(15,23,42,0.06));
      rotate: 45deg;
    }

    /* ═══ FLOATING SIDE WIDGET ═══ */
    .reviews-side-widget {
      position: fixed;
      left: 20px;
      bottom: 20px;
      z-index: 9000;
      display: none;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      transition: transform 0.3s ease;
    }
    .reviews-side-widget.ready { display: flex; }
    @media (max-width: 540px) { .reviews-side-widget { left: 12px; bottom: 12px; } }
    .reviews-side-tab {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 18px;
      background: var(--bg-white, #FFFFFF);
      border: 1px solid var(--border-light, rgba(15,23,42,0.08));
      border-radius: 999px;
      box-shadow: var(--shadow-md, 0 4px 16px rgba(0,0,0,0.12));
      cursor: pointer;
      color: var(--text-primary, var(--text-dark, #0D1117));
      font-family: var(--font-heading, system-ui);
      font-size: 13px;
      font-weight: 600;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .reviews-side-tab:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg, 0 16px 48px rgba(0,212,255,0.15)); }
    .reviews-side-tab-stars { display: inline-flex; gap: 1px; color: #F59E0B; }
    .reviews-side-tab-stars svg { width: 12px; height: 12px; }

    .reviews-side-panel {
      display: none;
      width: 280px;
      max-width: calc(100vw - 32px);
      background: var(--bg-white, #FFFFFF);
      border: 1px solid var(--border-light, rgba(15,23,42,0.08));
      border-radius: var(--radius-lg, 16px);
      box-shadow: var(--shadow-lg, 0 16px 48px rgba(0,0,0,0.18));
      overflow: hidden;
      animation: rev-side-in 0.3s ease;
    }
    @media (max-width: 540px) {
      .reviews-side-panel { width: 260px; }
      .reviews-side-tab { padding: 10px 14px; font-size: 12px; }
      .reviews-side-tab-stars svg { width: 10px; height: 10px; }
    }
    .reviews-side-widget.open .reviews-side-panel { display: block; }
    .reviews-side-widget.open .reviews-side-tab { display: none; }
    @keyframes rev-side-in {
      from { opacity: 0; transform: translateY(20px) scale(0.96); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    .reviews-side-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      padding: 14px 18px;
      border-bottom: 1px solid var(--border-light, rgba(15,23,42,0.06));
    }
    .reviews-side-title {
      font-family: var(--font-heading, system-ui);
      font-size: 13px;
      font-weight: 700;
      color: var(--text-primary, var(--text-dark, #0D1117));
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .reviews-side-title-stars { display: inline-flex; gap: 1px; color: #F59E0B; }
    .reviews-side-title-stars svg { width: 12px; height: 12px; }
    .reviews-side-close {
      width: 28px; height: 28px;
      border-radius: 50%;
      border: none;
      background: var(--border-light, rgba(15,23,42,0.05));
      color: var(--text-tertiary, rgba(15,23,42,0.5));
      cursor: pointer;
      font-size: 16px;
      line-height: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s ease, color 0.2s ease;
    }
    .reviews-side-close:hover { background: var(--text-tertiary, rgba(15,23,42,0.1)); color: var(--text-primary, var(--text-dark, #0D1117)); }
    .reviews-side-grid {
      height: 240px;
      overflow: hidden;
      padding: 4px;
      position: relative;
      mask-image: linear-gradient(to bottom, transparent 0, #000 24px, #000 calc(100% - 24px), transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, transparent 0, #000 24px, #000 calc(100% - 24px), transparent 100%);
    }
    .reviews-side-track {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 4px;
      animation: reviews-side-flow 22s linear infinite;
      will-change: transform;
    }
    .reviews-side-grid:hover .reviews-side-track { animation-play-state: paused; }
    @keyframes reviews-side-flow {
      0% { transform: translateY(0); }
      100% { transform: translateY(-50%); }
    }
    .reviews-side-thumb {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      cursor: zoom-in;
      border-radius: var(--radius-sm, 8px);
      transition: transform 0.2s ease, opacity 0.2s ease;
      display: block;
    }
    .reviews-side-thumb:hover { transform: scale(1.04); opacity: 0.92; }
    .reviews-side-cta-wrap { padding: 12px 14px 14px; }
    .reviews-side-cta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      padding: 12px 18px;
      background: var(--gradient-cta, linear-gradient(135deg, var(--primary, #00D4FF), var(--secondary, var(--accent, #FF6B35))));
      color: #fff;
      text-decoration: none;
      font-family: var(--font-heading, system-ui);
      font-weight: 700;
      font-size: 13px;
      border-radius: var(--radius-md, 12px);
      box-shadow: var(--shadow-primary, 0 8px 32px rgba(0,212,255,0.25));
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      animation: reviews-side-pulse 2.4s ease-in-out infinite;
      will-change: transform, box-shadow;
    }
    .reviews-side-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(0,212,255,0.4);
      animation-play-state: paused;
    }
    .reviews-side-cta svg { width: 14px; height: 14px; }
    @keyframes reviews-side-pulse {
      0%, 100% {
        transform: translateY(0) scale(1);
        box-shadow: var(--shadow-primary, 0 8px 32px rgba(0,212,255,0.25));
      }
      50% {
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 14px 40px rgba(0,212,255,0.55);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .reviews-side-cta { animation: none; }
      .reviews-side-track { animation: none; }
    }

    /* ═══ LIGHTBOX ═══ */
    .reviews-lightbox {
      position: fixed; inset: 0;
      background: rgba(15, 23, 42, 0.94);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      z-index: 9999;
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .reviews-lightbox.show { display: flex; animation: rev-lb-fade 0.25s ease; }
    @keyframes rev-lb-fade { from { opacity: 0; } to { opacity: 1; } }
    .reviews-lightbox-stage {
      flex: 1;
      width: 100%;
      max-width: 1100px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      min-height: 0;
    }
    .reviews-lightbox-img {
      max-width: 100%;
      max-height: 70vh;
      object-fit: contain;
      border-radius: var(--radius-md, 12px);
      box-shadow: 0 30px 80px rgba(0,0,0,0.5);
      user-select: none;
      touch-action: pan-y pinch-zoom;
      opacity: 0;
      transition: opacity 0.25s ease;
      display: block;
    }
    .reviews-lightbox-img.loaded { opacity: 1; }
    .reviews-lightbox-spinner {
      position: absolute;
      width: 36px; height: 36px;
      border: 3px solid rgba(255,255,255,0.15);
      border-top-color: rgba(255,255,255,0.9);
      border-radius: 50%;
      animation: rev-spin 0.8s linear infinite;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.2s ease;
    }
    .reviews-lightbox-spinner.show { opacity: 1; }
    @keyframes rev-spin { to { transform: rotate(360deg); } }
    .reviews-lightbox-close,
    .reviews-lightbox-prev,
    .reviews-lightbox-next {
      position: absolute;
      width: 48px; height: 48px;
      border-radius: 50%;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      color: #fff;
      font-size: 28px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s ease, transform 0.2s ease;
      z-index: 2;
      line-height: 1;
    }
    .reviews-lightbox-close:hover,
    .reviews-lightbox-prev:hover,
    .reviews-lightbox-next:hover {
      background: rgba(255,255,255,0.22);
      transform: scale(1.05);
    }
    .reviews-lightbox-close { top: 24px; right: 24px; font-size: 22px; position: fixed; }
    .reviews-lightbox-prev { left: 24px; top: 50%; transform: translateY(-50%); }
    .reviews-lightbox-next { right: 24px; top: 50%; transform: translateY(-50%); }
    .reviews-lightbox-prev:hover { transform: translateY(-50%) scale(1.05); }
    .reviews-lightbox-next:hover { transform: translateY(-50%) scale(1.05); }
    .reviews-lightbox-caption {
      margin: 18px auto 0;
      max-width: 640px;
      width: 100%;
      text-align: center;
      color: rgba(255,255,255,0.85);
      font-family: var(--font-body, system-ui);
      font-size: 13px;
      line-height: 1.55;
      padding: 0 16px;
    }
    .reviews-lightbox-caption-meta { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 8px; }
    .reviews-lightbox-caption-stars { display: inline-flex; gap: 1px; color: #FFC107; }
    .reviews-lightbox-caption-stars svg { width: 14px; height: 14px; }
    .reviews-lightbox-caption-text {
      color: rgba(255,255,255,0.7);
      font-style: italic;
      max-width: 520px;
      margin: 0 auto;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .reviews-lightbox-counter {
      color: rgba(255,255,255,0.6);
      font-family: var(--font-body, system-ui);
      font-size: 12px;
      background: rgba(0,0,0,0.4);
      padding: 5px 12px;
      border-radius: 999px;
      margin: 12px 0 8px;
      letter-spacing: 0.04em;
    }
    .reviews-lightbox-cta {
      margin-top: 14px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 36px;
      background: var(--gradient-cta, linear-gradient(135deg, var(--primary, #00D4FF), var(--secondary, var(--accent, #FF6B35))));
      color: #fff;
      font-family: var(--font-heading, system-ui);
      font-weight: 700;
      font-size: 15px;
      border-radius: var(--radius-md, 12px);
      text-decoration: none;
      box-shadow: var(--shadow-primary, 0 8px 32px rgba(0,212,255,0.25));
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      letter-spacing: 0.01em;
    }
    .reviews-lightbox-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 36px rgba(0,212,255,0.4);
    }
    .reviews-lightbox-cta svg { width: 18px; height: 18px; }
    .reviews-lightbox-hint {
      color: rgba(255,255,255,0.4);
      font-family: var(--font-body, system-ui);
      font-size: 11px;
      margin-top: 14px;
      letter-spacing: 0.04em;
    }
    @media (max-width: 720px) {
      .reviews-lightbox { padding: 16px; }
      .reviews-lightbox-prev,
      .reviews-lightbox-next { width: 40px; height: 40px; font-size: 22px; }
      .reviews-lightbox-close { width: 40px; height: 40px; top: 16px; right: 16px; font-size: 18px; }
      .reviews-lightbox-cta {
        padding: 14px 28px;
        font-size: 14px;
        width: 100%;
        max-width: 360px;
        justify-content: center;
      }
      .reviews-lightbox-img { max-height: 56vh; }
      .reviews-lightbox-caption { font-size: 12px; }
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="container">
      <div class="header-inner">
        <a href="#" class="logo">
          <img src="https://yxmavwkwnfuphjqbelws.supabase.co/storage/v1/object/public/attachments/landing/innerscan/logo.png" alt="InnerScan">
        </a>

        <nav class="nav-desktop">
          <a href="#features" class="nav-link">Funkcje</a>
          <a href="#how-it-works" class="nav-link">Jak działa</a>
          <a href="#testimonials" class="nav-link">Opinie</a>
          <a href="#faq" class="nav-link">FAQ</a>
        </nav>

        <a href="https://innerscan.pl/checkout?products=103035094" class="btn-primary header-cta">Zamów teraz</a>

        <button class="hamburger" id="hamburger" aria-label="Menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="#features" class="mobile-link">Funkcje</a>
    <a href="#how-it-works" class="mobile-link">Jak działa</a>
    <a href="#testimonials" class="mobile-link">Opinie</a>
    <a href="#faq" class="mobile-link">FAQ</a>
    <a href="https://innerscan.pl/checkout?products=103035094" class="btn-primary mobile-cta">Zamów teraz</a>
  </div>

  <!-- Hero -->
  <!-- VIDEOS:STORIES:START -->
  <style>
    /* MOBILE-FIRST: kompaktowy horizontal pasek pod headerem */
    .stories-bar {
      position: sticky;
      top: 70px;
      z-index: 99;
      padding: 7px 0;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(0, 168, 150, 0.08);
    }
    .stories-bar-inner {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 0 16px;
      max-width: var(--container-width, 1200px);
      margin: 0 auto;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .stories-bar-inner::-webkit-scrollbar { display: none; }

    .stories-bar-label {
      font-family: var(--font-accent, monospace);
      font-size: 9px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--primary, #00A896);
      flex-shrink: 0;
      padding-right: 4px;
    }

    /* Story ring (kółeczko ze spinning gradientem) */
    .story-ring {
      position: relative;
      width: 44px;
      height: 44px;
      flex-shrink: 0;
      cursor: pointer;
      border-radius: 50%;
      padding: 2px;
      background: conic-gradient(from 0deg, #833AB4, #FD1D1D, #FCB045, #00A896, #833AB4);
      animation: story-spin 4s linear infinite;
      transition: transform 0.25s ease;
      border: none;
      outline: none;
    }
    .story-ring:hover {
      animation-play-state: paused;
      transform: scale(1.1);
    }
    .story-ring.story-ring--seen {
      background: #c7c9d2;
      animation: none;
    }
    @keyframes story-spin { to { transform: rotate(360deg); } }
    @media (prefers-reduced-motion: reduce) {
      .story-ring { animation: none; }
    }

    .story-ring-inner {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background: #fff;
      padding: 2px;
      display: block;
    }
    .story-ring-img {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      object-fit: cover;
      display: block;
    }
    /* Badges per-platforma — usunięte, redundant gdy wszystko YT */
    .story-ring-platform { display: none; }

    /* DESKTOP: floating pionowy widget na prawej krawędzi */
    @media (min-width: 769px) {
      .stories-bar {
        position: fixed;
        top: 50%;
        right: 16px;
        transform: translateY(-50%);
        padding: 10px 8px;
        border-radius: 26px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(0, 168, 150, 0.12);
        box-shadow:
          0 12px 36px rgba(0, 0, 0, 0.10),
          0 0 0 1px rgba(0, 168, 150, 0.04),
          inset 0 1px 0 rgba(255, 255, 255, 0.7);
        z-index: 95;
        opacity: 0;
        animation: stories-widget-in 0.7s 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards,
                   stories-widget-bounce 6s 3s ease-in-out infinite;
        will-change: transform;
      }
      @keyframes stories-widget-in {
        from { opacity: 0; transform: translateY(-50%) translateX(60px); }
        to   { opacity: 1; transform: translateY(-50%) translateX(0); }
      }
      @keyframes stories-widget-bounce {
        0%, 90%, 100% { transform: translateY(-50%) translateX(0); }
        93%  { transform: translateY(-50%) translateX(-5px); }
        96%  { transform: translateY(-50%) translateX(2px); }
        99%  { transform: translateY(-50%) translateX(-1px); }
      }
      .stories-bar:hover {
        animation-play-state: paused;
        transform: translateY(-50%) translateX(-3px);
        box-shadow:
          0 18px 48px rgba(0, 0, 0, 0.14),
          0 0 0 1px rgba(0, 168, 150, 0.18),
          0 0 32px rgba(0, 168, 150, 0.12);
        transition: transform 0.3s, box-shadow 0.3s;
      }
      .stories-bar-inner {
        flex-direction: column;
        gap: 8px;
        padding: 0;
        max-width: none;
        overflow: visible;
      }
      .stories-bar-label {
        font-size: 8px;
        letter-spacing: 1.5px;
        padding: 2px 0 6px;
        margin-bottom: 2px;
        color: var(--primary, #00A896);
        text-align: center;
        width: 100%;
        border-bottom: 1px solid rgba(0, 168, 150, 0.1);
      }
      /* Większe kółka na desktop dla lepszej widoczności */
      .story-ring { width: 56px; height: 56px; padding: 2.5px; }
      @media (prefers-reduced-motion: reduce) {
        .stories-bar { animation: stories-widget-in 0.4s ease forwards; }
      }
    }
    @media (min-width: 769px) and (max-width: 1100px) {
      .stories-bar { right: 10px; }
    }
    @media (min-width: 769px) and (max-height: 620px) {
      .stories-bar {
        max-height: calc(100vh - 32px);
        overflow-y: auto;
      }
      .stories-bar::-webkit-scrollbar { display: none; }
    }
  </style>
