  <script>
    (function initReels() {
      const section = document.querySelector('.reels');
      if (!section) return;

      const phones = Array.from(document.querySelectorAll('.reel-phone[data-yt-id]'));
      if (phones.length === 0) return;
      const track = document.getElementById('reelsTrack');
      const progressBars = Array.from(document.querySelectorAll('.reels-progress-bar'));
      const CTA_URL = 'https://innerscan.pl/checkout?products=103035094';

      let activeIdx = 0;
      let sectionPlayer = null;
      let progressRaf = null;
      let progressStart = 0;
      let progressDuration = 0;
      let ytApiReady = false;
      let ytApiLoading = false;
      let ytApiCallbacks = [];
      let autoplayStarted = false;
      let autoplayPaused = false;

      // ═══ Carousel: klasy + recenter (linear, bez cyclical wrap) ═══
      function applyClasses() {
        phones.forEach((p, idx) => {
          const abs = Math.abs(idx - activeIdx);
          p.classList.remove('reel-phone--active', 'reel-phone--peek', 'reel-phone--peek-far');
          if (abs === 0) p.classList.add('reel-phone--active');
          else if (abs === 1) p.classList.add('reel-phone--peek');
          else p.classList.add('reel-phone--peek-far');
        });
      }

      function recenterTrack() {
        const phone = phones[activeIdx];
        if (!phone || !track) return;
        // offsetLeft/offsetWidth ignoruje transformy → pozwala policzyć natural center
        const trackWidth = track.offsetWidth;
        const phoneCenter = phone.offsetLeft + phone.offsetWidth / 2;
        const delta = (trackWidth / 2) - phoneCenter;
        track.style.transform = 'translate(calc(-50% + ' + delta + 'px), -50%)';
      }

      function setActive(i, doRecenter) {
        if (typeof doRecenter !== 'boolean') doRecenter = true;
        activeIdx = ((i % phones.length) + phones.length) % phones.length;
        applyClasses();
        updateProgressBars();
        if (doRecenter) {
          requestAnimationFrame(() => recenterTrack());
        }
      }

      function updateProgressBars(activePct) {
        progressBars.forEach((b, idx) => {
          const span = b.querySelector('span');
          b.classList.remove('reels-progress-bar--filled');
          if (!span) return;
          if (idx < activeIdx) {
            b.classList.add('reels-progress-bar--filled');
          } else if (idx > activeIdx) {
            span.style.width = '0';
          } else if (typeof activePct === 'number') {
            span.style.width = activePct + '%';
          } else {
            span.style.width = '0';
          }
        });
      }

      // ═══ Progress timer dla aktywnego video ═══
      function startProgress(durationMs) {
        stopProgress();
        progressStart = Date.now();
        progressDuration = durationMs;
        const span = progressBars[activeIdx] && progressBars[activeIdx].querySelector('span');
        if (!span) return;
        span.style.width = '0';
        function tick() {
          const elapsed = Date.now() - progressStart;
          const pct = Math.min(100, (elapsed / progressDuration) * 100);
          span.style.width = pct + '%';
          if (pct < 100 && progressRaf !== null) {
            progressRaf = requestAnimationFrame(tick);
          }
        }
        progressRaf = requestAnimationFrame(tick);
      }
      function stopProgress() {
        if (progressRaf !== null) {
          cancelAnimationFrame(progressRaf);
          progressRaf = null;
        }
      }

      // ═══ YouTube iframe API loader ═══
      function ensureYtApi(callback) {
        if (window.YT && window.YT.Player && ytApiReady) { callback(); return; }
        ytApiCallbacks.push(callback);
        if (ytApiLoading) return;
        ytApiLoading = true;
        const tag = document.createElement('script');
        tag.src = 'https://www.youtube.com/iframe_api';
        document.head.appendChild(tag);
        const prev = window.onYouTubeIframeAPIReady;
        window.onYouTubeIframeAPIReady = function() {
          ytApiReady = true;
          ytApiCallbacks.forEach(function(cb){ try { cb(); } catch(e) { console.error(e); } });
          ytApiCallbacks = [];
          if (typeof prev === 'function') { try { prev(); } catch(e) {} }
        };
      }

      // ═══ Section autoplay ═══
      function destroySectionPlayer() {
        if (sectionPlayer) {
          try { sectionPlayer.destroy(); } catch (_) {}
          sectionPlayer = null;
        }
        phones.forEach(function(p) {
          const screen = p.querySelector('.reel-phone-screen');
          const playerDiv = screen && screen.querySelector('.reel-phone-player');
          if (playerDiv) playerDiv.remove();
          p.classList.remove('reel-phone--playing');
        });
        stopProgress();
      }

      function playActiveInSection() {
        if (autoplayPaused) return;
        destroySectionPlayer();
        const phone = phones[activeIdx];
        const ytId = phone && phone.dataset.ytId;
        if (!ytId) return;
        const screen = phone.querySelector('.reel-phone-screen');
        if (!screen) return;

        const playerDiv = document.createElement('div');
        playerDiv.className = 'reel-phone-player';
        const playerId = 'reel-player-' + Date.now() + '-' + activeIdx;
        playerDiv.id = playerId;
        screen.appendChild(playerDiv);

        try {
          sectionPlayer = new YT.Player(playerId, {
            videoId: ytId,
            playerVars: {
              autoplay: 1,
              mute: 1,
              controls: 0,
              rel: 0,
              modestbranding: 1,
              playsinline: 1,
              loop: 0,
              iv_load_policy: 3,
              fs: 0,
              disablekb: 1
            },
            events: {
              onReady: function(e) {
                try {
                  // Crop hack — iframe 16:9 wysrodkowany w 9:16 frame (defensive: backup jesli CSS nie zlapal)
                  const ifr = e.target.getIframe();
                  if (ifr) {
                    ifr.style.cssText = 'position:absolute !important; top:50% !important; left:50% !important; height:100% !important; width:177.778% !important; transform:translate(-50%, -50%) !important; border:0 !important; pointer-events:none !important;';
                  }
                  e.target.mute();
                  e.target.playVideo();
                  phone.classList.add('reel-phone--playing');
                  const dur = e.target.getDuration() * 1000;
                  if (dur > 0) startProgress(dur);
                } catch (err) { console.error(err); }
              },
              onStateChange: function(e) {
                if (e.data === YT.PlayerState.ENDED) {
                  stopProgress();
                  updateProgressBars(100);
                  setTimeout(advanceToNext, 350);
                } else if (e.data === YT.PlayerState.PLAYING) {
                  phone.classList.add('reel-phone--playing');
                  if (!progressRaf) {
                    const dur = e.target.getDuration() * 1000;
                    if (dur > 0) startProgress(dur);
                  }
                }
              },
              onError: function() {
                setTimeout(advanceToNext, 600);
              }
            }
          });
        } catch (e) { console.error(e); }
      }

      function advanceToNext() {
        // Po ostatnim video — zatrzymaj autoplay (user wciska progress bar zeby restart)
        if (activeIdx >= phones.length - 1) {
          updateProgressBars(100);
          phones[activeIdx].classList.remove('reel-phone--playing');
          return;
        }
        setActive(activeIdx + 1);
        setTimeout(playActiveInSection, 700);
      }

      // ═══ Click handlery: phone + progress ═══
      phones.forEach(function(p, i) {
        p.addEventListener('click', function() {
          if (i === activeIdx) {
            openLightbox(i);
          } else {
            setActive(i);
            if (autoplayStarted && !autoplayPaused) {
              setTimeout(playActiveInSection, 700);
            }
          }
        });
      });

      progressBars.forEach(function(b, i) {
        b.addEventListener('click', function() {
          setActive(i);
          if (autoplayStarted && !autoplayPaused) {
            setTimeout(playActiveInSection, 700);
          }
        });
      });

      // ═══ IntersectionObserver: start autoplay gdy 30%+ widoczne (mobile-friendly) ═══
      // 0.3 zamiast 0.8 — na mobile sekcja moze byc dluzsza od viewport,
      // ratio nigdy nie osiagnie 0.8. 0.3 = wystarczajaco zeby start.
      const obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting && e.intersectionRatio >= 0.3 && !autoplayStarted) {
            autoplayStarted = true;
            ensureYtApi(playActiveInSection);
          }
          if (autoplayStarted) {
            if (e.intersectionRatio < 0.1 && !autoplayPaused) {
              autoplayPaused = true;
              if (sectionPlayer) try { sectionPlayer.pauseVideo(); } catch (_) {}
              stopProgress();
            } else if (e.intersectionRatio >= 0.3 && autoplayPaused) {
              autoplayPaused = false;
              if (sectionPlayer) try { sectionPlayer.playVideo(); } catch (_) {}
            }
          }
        });
      }, { threshold: [0, 0.1, 0.3, 0.5, 1] });
      obs.observe(section);

      // Recenter on resize
      let resizeTimer;
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(recenterTrack, 200);
      });

      // Init
      requestAnimationFrame(function() {
        applyClasses();
        setTimeout(recenterTrack, 50);
      });

      // ═══ Stories click → lightbox ═══
      document.querySelectorAll('.story-ring[data-video-idx]').forEach(function(ring) {
        ring.addEventListener('click', function() {
          ring.classList.add('story-ring--seen');
          const i = parseInt(ring.dataset.videoIdx, 10) || 0;
          openLightbox(i);
        });
      });

      // ═══ LIGHTBOX ═══
      const lb = document.getElementById('reelsLightbox');
      const lbScroll = document.getElementById('reelsLbScroll');
      const lbClose = lb.querySelector('.reels-lb-close');
      const lbCounter = document.getElementById('reelsLbCounter');
      let lbBuilt = false;
      const lbPlayers = {};
      let lbCurrentIdx = 0;

      function buildLightbox() {
        if (lbBuilt) return;
        lbScroll.innerHTML = phones.map(function(p, i) {
          const ytId = p.dataset.ytId;
          const platform = p.dataset.platform || 'youtube';
          const url = p.dataset.url || '#';
          let frame = '';
          if (platform === 'youtube' && ytId) {
            frame = '<div class="reels-lb-player" data-yt-id="' + ytId + '" id="reels-lb-player-' + i + '"></div>';
          } else {
            const iconCls = 'reels-lb-link-icon--' + platform;
            const label = platform === 'instagram' ? 'Otwórz na Instagram' : (platform === 'tiktok' ? 'Otwórz na TikTok' : 'Otwórz video');
            frame = '<a class="reels-lb-link" href="' + url + '" target="_blank" rel="noopener">' +
              '<span class="reels-lb-link-icon ' + iconCls + '"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg></span>' +
              '<span class="reels-lb-link-label">' + label + '</span>' +
              '<span class="reels-lb-link-sub">Otworzy się w nowej karcie</span>' +
              '</a>';
          }
          return '<div class="reels-lb-slide" data-slide-idx="' + i + '">' +
            '<div class="reels-lb-frame">' + frame + '</div>' +
            '<a class="reels-lb-slide-cta" href="' + CTA_URL + '">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>' +
            '<span>Dodaj do koszyka</span>' +
            '</a>' +
            '</div>';
        }).join('');
        lbBuilt = true;
      }

      function ensureLbPlayer(idx, autoplay) {
        if (idx < 0 || idx >= phones.length) return;
        if (lbPlayers[idx]) {
          if (autoplay) playLbPlayer(idx);
          return;
        }
        const phone = phones[idx];
        if (!phone || !phone.dataset.ytId) return;
        ensureYtApi(function() {
          if (lbPlayers[idx]) {
            if (autoplay) playLbPlayer(idx);
            return;
          }
          const playerEl = document.getElementById('reels-lb-player-' + idx);
          if (!playerEl) return;
          try {
            lbPlayers[idx] = new YT.Player('reels-lb-player-' + idx, {
              videoId: phone.dataset.ytId,
              playerVars: {
                autoplay: autoplay ? 1 : 0,
                mute: 1,
                controls: 0,
                rel: 0,
                modestbranding: 1,
                playsinline: 1,
                iv_load_policy: 3,
                fs: 0,
                disablekb: 1
              },
              events: {
                onReady: function(e) {
                  try {
                    // Crop hack — iframe 16:9 wysrodkowany w 9:16 frame
                    const ifr = e.target.getIframe();
                    if (ifr) {
                      ifr.style.cssText = 'position:absolute !important; top:50% !important; left:50% !important; height:100% !important; width:177.778% !important; transform:translate(-50%, -50%) !important; border:0 !important;';
                    }
                  } catch (err) { console.error(err); }
                }
              }
            });
          } catch (e) { console.error(e); }
        });
      }

      function pauseLbPlayer(idx) {
        const p = lbPlayers[idx];
        if (p && typeof p.pauseVideo === 'function') {
          try { p.pauseVideo(); } catch (_) {}
        }
      }
      function playLbPlayer(idx) {
        const p = lbPlayers[idx];
        if (p && typeof p.playVideo === 'function') {
          try { p.playVideo(); } catch (_) {}
        }
      }

      function openLightbox(startIdx) {
        // Pauza sekcji
        autoplayPaused = true;
        if (sectionPlayer) { try { sectionPlayer.pauseVideo(); } catch (_) {} }
        stopProgress();

        buildLightbox();
        lb.classList.add('show');
        document.body.style.overflow = 'hidden';

        lbCurrentIdx = startIdx;
        updateLbCounter(startIdx);

        // Scroll do startIdx (bezpośrednio scrollTop — niezawodne na mobile Safari)
        lbScroll.style.scrollBehavior = 'auto';
        const slideHeight = lbScroll.clientHeight;
        if (slideHeight > 0) {
          lbScroll.scrollTop = startIdx * slideHeight;
        }
        requestAnimationFrame(function() {
          lbScroll.style.scrollBehavior = 'smooth';
        });

        ensureLbPlayer(startIdx, true);
        ensureLbPlayer(startIdx + 1, false);
        ensureLbPlayer(startIdx - 1, false);
      }

      function closeLightbox() {
        lb.classList.remove('show');
        document.body.style.overflow = '';
        Object.keys(lbPlayers).forEach(function(idx) { pauseLbPlayer(idx); });
        autoplayPaused = false;
        // Wznów autoplay sekcji jeśli widoczna
        setTimeout(function() {
          if (autoplayStarted) {
            const r = section.getBoundingClientRect();
            if (r.top < window.innerHeight && r.bottom > 0) {
              playActiveInSection();
            }
          }
        }, 300);
      }

      function updateLbCounter(idx) {
        if (lbCounter) lbCounter.textContent = (idx + 1) + ' / ' + phones.length;
      }

      // Scroll detection w lightbox (snap-aware)
      lbScroll.addEventListener('scroll', function() {
        const slideHeight = lbScroll.clientHeight;
        if (slideHeight === 0) return;
        const newIdx = Math.round(lbScroll.scrollTop / slideHeight);
        if (newIdx !== lbCurrentIdx && newIdx >= 0 && newIdx < phones.length) {
          pauseLbPlayer(lbCurrentIdx);
          lbCurrentIdx = newIdx;
          ensureLbPlayer(newIdx, true);
          ensureLbPlayer(newIdx + 1, false);
          ensureLbPlayer(newIdx - 1, false);
          updateLbCounter(newIdx);
        }
      }, { passive: true });

      lbClose.addEventListener('click', closeLightbox);
      // Klik gdziekolwiek POZA video frame i CTA zamyka lightbox
      // (kliki na frame przekazujemy do iframe = play/pause; kliki na CTA = redirect)
      lb.addEventListener('click', function(e) {
        if (e.target.closest('.reels-lb-frame, .reels-lb-slide-cta, .reels-lb-close')) return;
        closeLightbox();
      });
      document.addEventListener('keydown', function(e) {
        if (!lb.classList.contains('show')) return;
        if (e.key === 'Escape') closeLightbox();
        else if (e.key === 'ArrowDown' || e.key === 'PageDown') {
          e.preventDefault();
          const nextIdx = Math.min(phones.length - 1, lbCurrentIdx + 1);
          lbScroll.scrollTo({ top: nextIdx * lbScroll.clientHeight, behavior: 'smooth' });
        } else if (e.key === 'ArrowUp' || e.key === 'PageUp') {
          e.preventDefault();
          const prevIdx = Math.max(0, lbCurrentIdx - 1);
          lbScroll.scrollTo({ top: prevIdx * lbScroll.clientHeight, behavior: 'smooth' });
        }
      });
    })();
  </script>
  <!-- VIDEOS:REELS:END -->

  <section class="faq" id="faq">
    <div class="container">
      <div class="faq-header fade-in">
        <span class="section-label">FAQ</span>
        <h2 class="section-title">Najczęściej zadawane pytania</h2>
        <p class="section-subtitle">
          Masz wątpliwości? Znajdziesz tu odpowiedzi na najważniejsze pytania.
        </p>
      </div>

      <div class="faq-list">
        <div class="faq-item fade-in">
          <button class="faq-question">
            <span>Czy potrzebuję smartfona lub aplikacji do działania kamery?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Nie. InnerScan ma wbudowany ekran IPS 4.3" i działa całkowicie samodzielnie. Włączasz przyciskiem i od razu widzisz obraz. Żadnego parowania, żadnych aplikacji, żadnych problemów z kompatybilnością.
            </div>
          </div>
        </div>

        <div class="faq-item fade-in">
          <button class="faq-question">
            <span>Jak długo działa na baterii?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Wbudowany akumulator 2000mAh zapewnia 3-5 godzin nieprzerwanej pracy. Ładowanie przez standardowe USB-C — możesz użyć ładowarki od telefonu lub powerbanku.
            </div>
          </div>
        </div>

        <div class="faq-item fade-in">
          <button class="faq-question">
            <span>Czy kamera nagrywa wideo?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Ten model jest przeznaczony do inspekcji w czasie rzeczywistym i nie posiada funkcji nagrywania. Jeśli potrzebujesz dokumentacji, możesz nagrać ekran telefonem lub wybrać model z funkcją zapisu.
            </div>
          </div>
        </div>

        <div class="faq-item fade-in">
          <button class="faq-question">
            <span>Jaka jest długość przewodu?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Dostępne warianty to 5 lub 10 metrów. Przewód jest sztywny (semi-rigid) — zachowuje nadany kształt, co ułatwia manewrowanie w zagięciach rur i pionowych szybach.
            </div>
          </div>
        </div>

        <div class="faq-item fade-in">
          <button class="faq-question">
            <span>Czy mogę używać kamery w wodzie?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Tak. Głowica kamery i przewód mają certyfikat IP67 — całkowita pyłoszczelność i odporność na krótkotrwałe zanurzenie. Możesz bezpiecznie pracować w wilgotnych rurach, zaolejonych przekładniach i zalanych instalacjach.
            </div>
          </div>
        </div>

        <div class="faq-item fade-in">
          <button class="faq-question">
            <span>Jaka jest polityka zwrotów?</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Masz 30 dni na przetestowanie kamery. Jeśli nie będziesz zadowolony — zwracasz bez pytań. Dodatkowo otrzymujesz 24-miesięczną gwarancję producenta na wady fabryczne.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

