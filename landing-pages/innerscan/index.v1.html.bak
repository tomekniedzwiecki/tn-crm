  <!-- Sticky CTA (Mobile) -->
  <div class="sticky-cta" id="stickyCta">
    <div class="sticky-cta-inner">
      <div class="sticky-cta-price">
        <span class="old">499 PLN</span>
        <span class="new">299 PLN</span>
      </div>
      <a href="https://innerscan.pl/checkout?products=103035094" class="btn-primary">
        Zamów -40%
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- Cookie Banner -->
  <div class="cookie-banner" id="cookieBanner">
    <p>
      Ta strona używa plików cookie, aby zapewnić najlepsze doświadczenia.
      <a href="#">Dowiedz się więcej</a>
    </p>
    <div class="cookie-buttons">
      <button class="cookie-accept" id="cookieAccept">Akceptuję</button>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Intersection Observer for fade-in
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) e.target.classList.add('visible');
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

      // Hamburger menu
      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobileMenu');

      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active');
        mobileMenu.classList.toggle('open');
      });

      // Close mobile menu on link click
      document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => {
          hamburger.classList.remove('active');
          mobileMenu.classList.remove('open');
        });
      });

      // Spotlight effect for bento cards
      document.querySelectorAll('.bento-card').forEach(card => {
        const spotlight = card.querySelector('.spotlight');
        if (spotlight) {
          card.addEventListener('mousemove', (e) => {
            const rect = card.getBoundingClientRect();
            spotlight.style.left = (e.clientX - rect.left) + 'px';
            spotlight.style.top = (e.clientY - rect.top) + 'px';
          });
        }
      });

      // FAQ accordion
      document.querySelectorAll('.faq-question').forEach(button => {
        button.addEventListener('click', () => {
          const item = button.parentElement;
          const isActive = item.classList.contains('active');

          // Close all
          document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));

          // Open clicked if wasn't active
          if (!isActive) {
            item.classList.add('active');
          }
        });
      });

      // Cookie banner
      const cookieBanner = document.getElementById('cookieBanner');
      const cookieBtn = document.getElementById('cookieAccept');

      if (!localStorage.getItem('cookiesAccepted')) {
        setTimeout(() => cookieBanner.classList.add('show'), 2000);
      }

      cookieBtn.addEventListener('click', () => {
        localStorage.setItem('cookiesAccepted', 'true');
        cookieBanner.classList.remove('show');
      });

      // Sticky CTA (Mobile)
      const stickyCta = document.getElementById('stickyCta');
      const heroSection = document.querySelector('.hero');

      if (stickyCta && heroSection) {
        const stickyObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              stickyCta.classList.remove('visible');
            } else {
              stickyCta.classList.add('visible');
            }
          });
        }, { threshold: 0 });

        stickyObserver.observe(heroSection);
      }

    });
  </script>

  <!-- ═══════════════════════════════════════════════════════════
       WHATSAPP WIDGET (self-contained, inline)
  ═══════════════════════════════════════════════════════════ -->
  <style>
    .wa-widget { position: fixed; right: 20px; bottom: 20px; z-index: 9998; font-family: var(--font-body, system-ui); }
    @media (max-width: 540px) { .wa-widget { right: 14px; bottom: 14px; } }
    .wa-btn {
      width: 60px; height: 60px; border-radius: 50%;
      background: #25D366; color: #fff; border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 8px 24px rgba(37, 211, 102, 0.45);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      animation: wa-pulse 2.4s ease-in-out infinite;
    }
    .wa-btn:hover { transform: scale(1.06); box-shadow: 0 12px 32px rgba(37, 211, 102, 0.6); animation-play-state: paused; }
    .wa-btn svg { width: 30px; height: 30px; }
    @keyframes wa-pulse {
      0%, 100% { box-shadow: 0 8px 24px rgba(37, 211, 102, 0.45); }
      50%      { box-shadow: 0 8px 24px rgba(37, 211, 102, 0.45), 0 0 0 12px rgba(37, 211, 102, 0); }
    }
    @media (prefers-reduced-motion: reduce) { .wa-btn { animation: none; } }
    .wa-teaser {
      position: absolute; right: 74px; bottom: 12px;
      background: #fff; color: #1A1A2E;
      padding: 10px 14px; border-radius: 18px 18px 4px 18px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
      font-size: 13px; font-weight: 500; white-space: nowrap;
      opacity: 0; transform: translateX(8px); pointer-events: none;
      transition: opacity 0.3s ease, transform 0.3s ease;
      cursor: pointer;
    }
    .wa-teaser.wa-teaser--show { opacity: 1; transform: translateX(0); pointer-events: auto; }
    @media (max-width: 540px) {
      .wa-teaser { right: 68px; bottom: 10px; font-size: 12px; padding: 8px 12px; max-width: calc(100vw - 90px); white-space: normal; }
    }
    .wa-panel {
      position: absolute; right: 0; bottom: 76px;
      width: 320px; max-width: calc(100vw - 28px);
      background: #fff; border-radius: 16px;
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.18);
      overflow: hidden;
      opacity: 0; transform: translateY(8px) scale(0.98); pointer-events: none;
      transition: opacity 0.2s ease, transform 0.2s ease;
    }
    .wa-widget.wa-open .wa-panel { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
    .wa-panel-header { padding: 16px 18px; background: #075E54; color: #fff; display: flex; align-items: center; gap: 12px; }
    .wa-panel-header-icon { width: 38px; height: 38px; border-radius: 50%; background: #25D366; display: flex; align-items: center; justify-content: center; }
    .wa-panel-header-icon svg { width: 22px; height: 22px; color: #fff; }
    .wa-panel-header-text strong { display: block; font-size: 14px; font-weight: 700; }
    .wa-panel-header-text span { font-size: 12px; opacity: 0.85; }
    .wa-replies { padding: 8px; display: flex; flex-direction: column; gap: 4px; }
    .wa-reply { display: flex; align-items: center; gap: 12px; padding: 12px 14px; border-radius: 10px; text-decoration: none; color: #1A1A2E; transition: background 0.15s ease; }
    .wa-reply:hover { background: #F1F5F9; }
    .wa-reply-ico { font-size: 18px; line-height: 1; }
    .wa-reply-label { font-size: 14px; font-weight: 500; }
  </style>

  <div id="wa-widget" class="wa-widget" aria-label="Czat WhatsApp">
    <div class="wa-panel" role="dialog" aria-label="Wybierz temat rozmowy">
      <div class="wa-panel-header">
        <div class="wa-panel-header-icon"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg></div>
        <div class="wa-panel-header-text">
          <strong>Napisz do nas</strong>
          <span>Odpowiadamy zwykle w kilka minut</span>
        </div>
      </div>
      <div class="wa-replies"></div>
    </div>
    <div class="wa-teaser">Cześć! Pomożemy w wyborze 👋</div>
    <button type="button" class="wa-btn" aria-label="Otwórz czat WhatsApp"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg></button>
  </div>

  <script>
  (function initWaWidget() {
    var PHONE = '49510286688';
    var REPLIES = [
      { icon: '📞', label: 'Zamów przez telefon', message: 'Cześć! Chcę zamówić kamerę endoskopową InnerScan — proszę o kontakt telefoniczny.' },
      { icon: '💬', label: 'Pytanie o produkt',   message: 'Cześć! Mam pytanie o kamerę endoskopową InnerScan.' },
      { icon: '🚚', label: 'Pytanie o dostawę',   message: 'Cześć! Mam pytanie o dostawę kamery endoskopowej InnerScan.' },
      { icon: '🎯', label: 'Potrzebuję porady',   message: 'Cześć! Zastanawiam się nad zakupem kamery endoskopowej InnerScan — potrzebuję porady.' }
    ];
    var TEASERS = [
      'Cześć! Pomożemy w wyborze 👋',
      'Masz pytanie? Napisz do nas',
      'Zamów wygodnie przez czat'
    ];
    var widget = document.getElementById('wa-widget');
    if (!widget) return;
    var btn = widget.querySelector('.wa-btn');
    var teaser = widget.querySelector('.wa-teaser');
    var repliesList = widget.querySelector('.wa-replies');
    repliesList.innerHTML = REPLIES.map(function(r){
      return "<a class='wa-reply' target='_blank' rel='noopener' href='https://wa.me/" + PHONE + "?text=" + encodeURIComponent(r.message) + "'><span class='wa-reply-ico'>" + r.icon + "</span><span class='wa-reply-label'>" + r.label + "</span></a>";
    }).join('');
    btn.addEventListener('click', function(){ widget.classList.toggle('wa-open'); teaser.classList.remove('wa-teaser--show'); });
    document.addEventListener('click', function(e){ if (!widget.contains(e.target)) widget.classList.remove('wa-open'); });
    var teaserIdx = 0, teaserTimer;
    function showTeaser() {
      if (widget.classList.contains('wa-open')) return;
      teaser.textContent = TEASERS[teaserIdx % TEASERS.length];
      teaser.classList.add('wa-teaser--show');
      clearTimeout(teaserTimer);
      teaserTimer = setTimeout(function(){ teaser.classList.remove('wa-teaser--show'); }, 6000);
      teaserIdx++;
    }
    teaser.addEventListener('click', function(){ teaser.classList.remove('wa-teaser--show'); widget.classList.add('wa-open'); });
    setTimeout(function(){ showTeaser(); setInterval(showTeaser, 14000); }, 8000);
  })();
  </script>

  <script data-template="reviews-js">
  (function initReviewsLightbox() {
    const lb = document.getElementById('reviews-lightbox');
    if (!lb) return;
    const cards = Array.from(document.querySelectorAll('.review-card'));
    const stage = lb.querySelector('.reviews-lightbox-img');
    const spinner = lb.querySelector('.reviews-lightbox-spinner');
    const cur = lb.querySelector('.reviews-lightbox-current');
    const total = lb.querySelector('.reviews-lightbox-total');
    const captionStars = lb.querySelector('.reviews-lightbox-caption-stars');
    const captionText = lb.querySelector('.reviews-lightbox-caption-text');
    const btnClose = lb.querySelector('.reviews-lightbox-close');
    const btnPrev = lb.querySelector('.reviews-lightbox-prev');
    const btnNext = lb.querySelector('.reviews-lightbox-next');

    const STAR_SVG = '<svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
    const gallery = [];
    cards.forEach(card => {
      const imgs = card.querySelectorAll('.review-images img');
      if (imgs.length === 0) return;
      const ratingEls = card.querySelectorAll('.review-rating svg');
      const rating = ratingEls.length || 5;
      const text = card.querySelector('.review-text')?.textContent?.trim() || '';
      imgs.forEach(img => { gallery.push({ src: img.src, rating, text, triggerEl: img }); });
    });
    if (gallery.length === 0) return;

    let idx = 0;
    let currentLoadToken = 0;

    function show(i) {
      idx = (i + gallery.length) % gallery.length;
      const item = gallery[idx];
      cur.textContent = idx + 1;
      total.textContent = gallery.length;
      captionStars.innerHTML = Array(item.rating).fill(STAR_SVG).join('');
      captionText.textContent = item.text;
      const token = ++currentLoadToken;
      stage.classList.remove('loaded');
      spinner.classList.add('show');
      const onLoaded = () => {
        if (token !== currentLoadToken) return;
        stage.classList.add('loaded');
        spinner.classList.remove('show');
      };
      const onErr = () => {
        if (token !== currentLoadToken) return;
        spinner.classList.remove('show');
      };
      stage.onload = onLoaded;
      stage.onerror = onErr;
      if (stage.src === item.src) stage.src = '';
      stage.alt = '';
      stage.src = item.src;
      if (stage.complete && stage.naturalWidth > 0) onLoaded();
      [gallery[(idx + 1) % gallery.length], gallery[(idx - 1 + gallery.length) % gallery.length]].forEach(adj => {
        if (adj && adj.src && adj.src !== item.src) {
          const p = new Image();
          p.referrerPolicy = 'no-referrer';
          p.src = adj.src;
        }
      });
    }
    function findIndexByImg(img) { return gallery.findIndex(g => g.triggerEl === img); }
    function open(i) {
      show(i);
      lb.classList.add('show');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      lb.classList.remove('show');
      document.body.style.overflow = '';
      stage.src = '';
      stage.classList.remove('loaded');
    }
    function next() { show(idx + 1); }
    function prev() { show(idx - 1); }

    cards.forEach(card => {
      card.querySelectorAll('.review-images img').forEach(img => {
        img.addEventListener('click', () => {
          const i = findIndexByImg(img);
          if (i >= 0) open(i);
        });
      });
    });
    btnClose.addEventListener('click', close);
    btnPrev.addEventListener('click', prev);
    btnNext.addEventListener('click', next);
    lb.addEventListener('click', (e) => {
      if (e.target === lb || e.target.classList.contains('reviews-lightbox-stage')) close();
    });
    document.addEventListener('keydown', (e) => {
      if (!lb.classList.contains('show')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowRight') next();
      else if (e.key === 'ArrowLeft') prev();
    });

    let touchX = null, touchY = null;
    stage.addEventListener('touchstart', (e) => {
      if (e.touches.length !== 1) return;
      touchX = e.touches[0].clientX;
      touchY = e.touches[0].clientY;
    }, { passive: true });
    stage.addEventListener('touchend', (e) => {
      if (touchX === null) return;
      const dx = e.changedTouches[0].clientX - touchX;
      const dy = e.changedTouches[0].clientY - touchY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
        if (dx > 0) prev(); else next();
      }
      touchX = null;
    }, { passive: true });

    const trigger = document.querySelector('.reviews-disclosure-trigger');
    const popover = document.querySelector('.reviews-disclosure-popover');
    if (trigger && popover) {
      trigger.addEventListener('click', () => {
        const isOpen = popover.classList.toggle('show');
        trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
      document.addEventListener('click', (e) => {
        if (!popover.classList.contains('show')) return;
        if (e.target === trigger || trigger.contains(e.target)) return;
        if (!popover.contains(e.target)) {
          popover.classList.remove('show');
          trigger.setAttribute('aria-expanded', 'false');
        }
      });
    }

    const widget = document.getElementById('reviews-side-widget');
    if (widget && gallery.length > 0) {
      const grid = widget.querySelector('[data-side-grid]');
      const tab = widget.querySelector('.reviews-side-tab');
      const closeBtn = widget.querySelector('.reviews-side-close');

      const seen = new Set();
      const picks = [];
      for (const item of gallery) {
        if (seen.has(item.src)) continue;
        seen.add(item.src);
        picks.push(item);
        if (picks.length >= 12) break;
      }
      while (picks.length < 6 && picks.length > 0) {
        picks.push(...picks.slice(0, 6 - picks.length));
      }
      function thumbHtml(item) {
        const fullIdx = gallery.findIndex(g => g.src === item.src);
        return `<img class="reviews-side-thumb" src="${item.src}" alt="" loading="lazy" referrerpolicy="no-referrer" data-gallery-idx="${fullIdx >= 0 ? fullIdx : 0}">`;
      }
      const trackInner = picks.map(thumbHtml).join('');
      grid.innerHTML = `<div class="reviews-side-track">${trackInner}${trackInner}</div>`;

      grid.querySelectorAll('.reviews-side-thumb').forEach(img => {
        img.addEventListener('click', () => {
          const i = parseInt(img.dataset.galleryIdx, 10) || 0;
          open(i);
        });
      });
      tab.addEventListener('click', () => widget.classList.add('open'));
      closeBtn.addEventListener('click', () => widget.classList.remove('open'));

      let firstReadyDone = false;
      const desktopMQ = matchMedia('(min-width: 1080px)');
      function checkScroll() {
        if (window.scrollY > 300) {
          widget.classList.add('ready');
          if (!firstReadyDone && desktopMQ.matches) {
            widget.classList.add('open');
            firstReadyDone = true;
          }
        } else {
          widget.classList.remove('ready');
        }
      }
      checkScroll();
      window.addEventListener('scroll', checkScroll, { passive: true });
    }
  })();
  </script>
</body>
</html>
