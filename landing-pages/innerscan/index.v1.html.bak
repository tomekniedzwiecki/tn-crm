  <div id="reelsLightbox" class="reels-lightbox" role="dialog" aria-modal="true" aria-label="Galeria Reels">
    <button type="button" class="reels-lb-close" aria-label="Zamknij">&times;</button>
    <div class="reels-lb-counter" id="reelsLbCounter">1 / 13</div>
