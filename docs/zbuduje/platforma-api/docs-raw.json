2c963f66afa6/pages","body":null}},{"method":"POST","path":"https://gateway.trevio.pl/partner/v1/stores/{websiteId}/pages","summary":"Creates a new subpage in the store.","pathParameters":[{"name":"websiteId","type":"string (uuid)","required":true}],"queryParameters":[],"requestBody":{"path":"string","name":"string (nullable)"},"example":{"method":"POST","path":"https://gateway.trevio.pl/partner/v1/stores/3fa85f64-5717-4562-b3fc-2c963f66afa6/pages","body":{"path":"example-page","name":"Example"}}},{"method":"PUT","path":"https://gateway.trevio.pl/partner/v1/stores/{websiteId}/pages/{locationId}/html","summary":"Overrides a page's content with a raw HTML block. Not implemented yet.","pathParameters":[{"name":"websiteId","type":"string (uuid)","required":true},{"name":"locationId","type":"string (uuid)","required":true}],"queryParameters":[],"requestBody":null,"example":{"method":"PUT","path":"https://gateway.trevio.pl/partner/v1/stores/3fa85f64-5717-4562-b3fc-2c963f66afa6/pages/3fa85f64-5717-4562-b3fc-2c963f66afa6/html","body":null}},{"method":"GET","path":"https://gateway.trevio.pl/partner/v1/stores/{websiteId}/products","summary":"Returns a paginated list of the store's products, each with its variants, prices, and checkout links.","pathParameters":[{"name":"websiteId","type":"string (uuid)","required":true}],"queryParameters":[{"name":"Search","type":"string","required":false},{"name":"Page","type":"integer","required":false},{"name":"PageSize","type":"integer","required":false}],"requestBody":null,"example":{"method":"GET","path":"https://gateway.trevio.pl/partner/v1/stores/3fa85f64-5717-4562-b3fc-2c963f66afa6/products","body":null}},{"method":"POST","path":"https://gateway.trevio.pl/partner/v1/stores/{websiteId}/products","summary":"Creates a new product in the store.","pathParameters":[{"name":"websiteId","type":"string (uuid)","required":true}],"queryParameters":[],"requestBody":{"name":"string","price":"number"},"example":{"method":"POST","path":"https://gateway.trevio.pl/partner/v1/stores/3fa85f64-5717-4562-b3fc-2c963f66afa6/products","body":{"name":"Example","price":0}}},{"method":"PUT","path":"https://gateway.trevio.pl/partner/v1/stores/{websiteId}/products/{productId}/variants/{variantId}/checkout-link","summary":"Updates the checkout link (checkout slug) for a specific product variant.","pathParameters":[{"name":"websiteId","type":"string (uuid)","required":true},{"name":"productId","type":"string (uuid)","required":true},{"name":"variantId","type":"string (uuid)","required":true}],"queryParameters":[],"requestBody":{"checkoutSlug":"string (nullable)"},"example":{"method":"PUT","path":"https://gateway.trevio.pl/partner/v1/stores/3fa85f64-5717-4562-b3fc-2c963f66afa6/products/3fa85f64-5717-4562-b3fc-2c963f66afa6/variants/3fa85f64-5717-4562-b3fc-2c963f66afa6/checkout-link","body":{"checkoutSlug":"example-slug"}}}]}}