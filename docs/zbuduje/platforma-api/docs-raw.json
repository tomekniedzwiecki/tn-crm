{"status":200,"content_type":"application/json; charset=utf-8","data":{"service":"Niedzwiecki AI API","basePath":"https://gateway.trevio.pl/partner/v1","authentication":{"type":"apiKey","instructions":"Authenticate every request with your API key in the 'X-Api-Key' header. The key is scoped to a single partner and grants access to all of that partner's stores.","scope":"partner"},"rateLimiting":{"description":"Requests are rate limited per API key to 120 requests per 1-minute window. When you exceed the limit the API responds with HTTP 429 Too Many Requests, including a 'Retry-After' header (integer number of seconds to wait before retrying) plus 'RateLimit-Limit', 'RateLimit-Remaining' and 'RateLimit-Reset' (seconds until the window resets). Respect 'Retry-After' before sending further requests.","status":429,"limit":120,"windowSeconds":60,"retryAfterHeader":"Retry-After","informationalHeaders":["RateLimit-Limit","RateLimit-Remaining","RateLimit-Reset"]},"endpoints":[{"method":"GET","path":"https://gateway.trevio.pl/partner/v1/docs","summary":"Returns a machine-readable catalog of every available API endpoint, including each request's full URL, path/query parameters, request-body shape and a ready-to-use example — for programmatic discovery by the partner's integration code or AI agent.","pathParameters":[],"queryParameters":[],"requestBody":null,"example":{"method":"GET","path":"https://gateway.trevio.pl/partner/v1/docs","body":null}},{"method":"GET","path":"https://gateway.trevio.pl/partner/v1/stores","summary":"Returns the partner's stores, each with its identifier and active domain.","pathParameters":[],"queryParameters":[],"requestBody":null,"example":{"method":"GET","path":"https://gateway.trevio.pl/partner/v1/stores","body":null}},{"method":"PUT","path":"https://gateway.trevio.pl/partner/v1/stores/{websiteId}/branding/favicon","summary":"Uploads the store's favicon from a base64-encoded image (raw base64 or a data URI) and returns the stored URL.","pathParameters":[{"name":"websiteId","type":"string (uuid)","required":true}],"queryParameters":[],"requestBody":{"data":"string","fileName":"string (nullable)"},"example":{"method":"PUT","path":"https://gateway.trevio.pl/partner/v1/stores/3fa85f64-5717-4562-b3fc-2c963f66afa6/branding/favicon","body":{"data":"<base64-encoded-file>","fileName":"logo.png"}}},{"method":"PUT","path":"https://gateway.trevio.pl/partner/v1/stores/{websiteId}/branding/logo","summary":"Uploads the store's logo from a base64-encoded image (raw base64 or a data URI) and returns the stored URL.","pathParameters":[{"name":"websiteId","type":"string (uuid)","required":true}],"queryParameters":[],"requestBody":{"data":"string","fileName":"string (nullable)"},"example":{"method":"PUT","path":"https://gateway.trevio.pl/partner/v1/stores/3fa85f64-5717-4562-b3fc-2c963f66afa6/branding/logo","body":{"data":"<base64-encoded-file>","fileName":"logo.png"}}},{"method":"GET","path":"https://gateway.trevio.pl/partner/v1/stores/{websiteId}/delivery-methods","summary":"Returns the delivery methods currently configured for the store, with pricing per price group.","pathParameters":[{"name":"websiteId","type":"string (uuid)","required":true}],"queryParameters":[{"name":"Page","type":"integer","required":false},{"name":"PageSize","type":"integer","required":false}],"requestBody":null,"example":{"method":"GET","path":"https://gateway.trevio.pl/partner/v1/stores/3fa85f64-5717-4562-b3fc-2c963f66afa6/delivery-methods","body":null}},{"method":"POST","path":"https://gateway.trevio.pl/partner/v1/stores/{websiteId}/delivery-methods","summary":"Adds a delivery method to the store. Requires a delivery broker already attached to the store and a price group (see the options endpoint).","pathParameters":[{"name":"websiteId","type":"string (uuid)","required":true}],"queryParameters":[],"requestBody":{"name":"string","isCashOnDelivery":"boolean","externalServiceId":"string (nullable)","externalServiceName":"string (nullable)","deliveryBrokerId":"string (uuid)","priceGroupId":"string (uuid)","price":"number","freeAboveThreshold":"number (nullable)","deliveryMode":"string (enum: DoorToDoor | DoorToPoint | PointToPoint | PointToDoor)","pointsType":"string (nullable)","isVisibleInShop":"boolean","order":"integer"},"example":{"method":"POST","path":"https://gateway.trevio.pl/partner/v1/stores/3fa85f64-5717-4562-b3fc-2c963f66afa6/delivery-methods","body":{"name":"Example","isCashOnDelivery":false,"externalServiceId":"string","externalServiceName":"Example","deliveryBrokerId":"3fa85f64-5717-4562-b3fc-2c963f66afa6","priceGroupId":"3fa85f64-5717-4562-b3fc-2c963f66afa6","price":0,"freeAboveThreshold":0,"deliveryMode":"DoorToDoor","pointsType":"string","isVisibleInShop":false,"order":0}}},{"method":"GET","path":"https://gateway.trevio.pl/partner/v1/stores/{websiteId}/delivery-methods/options","summary":"Returns the delivery brokers attached to the store and the store's price groups — the identifiers required to add a delivery method.","pathParameters":[{"name":"websiteId","type":"string (uuid)","required":true}],"queryParameters":[],"requestBody":null,"example":{"method":"GET","path":"https://gateway.trevio.pl/partner/v1/stores/3fa85f64-5717-4562-b3fc-2c963f66afa6/delivery-methods/options","body":null}},{"method":"GET","path":"https://gateway.trevio.pl/partner/v1/stores/{websiteId}/domains","summary":"Returns all custom domains configured for the store, each with its DNS records and verification status.","pathParameters":[{"name":"websiteId","type":"string (uuid)","required":true}],"queryParameters":[],"requestBody":null,"example":{"method":"GET","path":"https://gateway.trevio.pl/partner/v1/stores/3fa85f64-5717-4562-b3fc-2c963f66afa6/domains","body":null}},{"method":"POST","path":"https://gateway.trevio.pl/partner/v1/stores/{websiteId}/domains","summary":"Adds a custom domain to the store together with its www variant, and returns the DNS records that must be created at the domain's registrar.","pathParameter