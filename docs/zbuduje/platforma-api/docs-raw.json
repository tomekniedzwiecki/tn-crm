  "limit": 120,
  "windowSeconds": 60,
  "retryAfterHeader": "Retry-After",
  "informationalHeaders": [
   "RateLimit-Limit",
   "RateLimit-Remaining",
   "RateLimit-Reset"
  ]
 },
