  {
   "topic": "custom-html-pages",
   "summary": "Any page of a store can be switched into custom-HTML mode. In that mode the storefront serves a raw HTML document you provide instead of the page's visual sections, so you can build fully bespoke landing pages while keeping the store's domain, checkout and tracking.",
   "notes": [
    "Create the page first with POST /stores/{websiteId}/pages, then set its HTML with PUT /stores/{websiteId}/pages/{locationId}/html.",
    "Send isHtml=true to make the storefront serve your HTML, and put the full document in the html field. Setting isHtml=false returns the page to its normal section-based rendering while keeping the stored HTML.",
    "The HTML is served for the exact page path; the home page is the page whose path is empty.",
    "Provide a complete, self-contained HTML body. Inline your own styles and scripts — the storefront does not inject a theme layout around custom-HTML pages."
   ],
   "analytics": {
    "globalObject": "window.trevio",
    "description": "Custom-HTML pages run the store's client analytics SDK as the global window.trevio object. PageView and a periodic heartbeat fire automatically on every custom-HTML page — never call those yourself. Call the interaction methods below to record shopper behavior; each maps to one analytics event type. Conventions: every method takes a single options object; prices and totals are plain numbers in the store's currency; currency is an ISO code such as 'PLN'; an item is { productId, name, price, quantity }; identityType is one of EmailHash, PhoneHash, CustomerId, ExternalCustomerId. A generic window.trevio.track(eventType, fields) is also available for advanced use.",
    "methods": [
     {
      "method": "window.trevio.pageView",
      "eventType": "PageView",
      "automatic": true,
      "signature": null,
      "example": null
     },
     {
      "method": "window.trevio.viewItem",
      "eventType": "ViewItem",
      "automatic": false,
      "signature": "{ currency, productId, name, price }",
      "example": "window.trevio.viewItem({ currency: 'PLN', productId: 'SKU-123', name: 'Koszulka', price: 49.99 })"
     },
     {
      "method": "window.trevio.viewItemList",
      "eventType": "ViewItemList",
      "automatic": false,
      "signature": "{ currency, items: [{ productId, name, price }] }",
      "example": "window.trevio.viewItemList({ currency: 'PLN', items: [{ productId: 'SKU-1', name: 'Koszulka', price: 49.99 }] })"
     },
     {
      "method": "window.trevio.selectItem",
      "eventType": "SelectItem",
      "automatic": false,
      "signature": "{ currency, productId, name, price }",
      "example": "window.trevio.selectItem({ currency: 'PLN', productId: 'SKU-123', name: 'Koszulka', price: 49.99 })"
     },
     {
      "method": "window.trevio.addToCart",
      "eventType": "AddToCart",
      "automatic": false,
      "signature": "{ currency, productId, name, price, quantity }",
      "example": "window.trevio.addToCart({ currency: 'PLN', productId: 'SKU-123', name: 'Koszulka', price: 49.99, quantity: 1 })"
     },
     {
      "method": "window.trevio.removeFromCart",
      "eventType": "RemoveFromCart",
      "automatic": false,
      "signature": "{ currency, productId, name, price, quantity }",
      "example": "window.trevio.removeFromCart({ currency: 'PLN', productId: 'SKU-123', name: 'Koszulka', price: 49.99, quantity: 1 })"
     },
     {
      "method": "window.trevio.viewCart",
      "eventType": "ViewCart",
      "automatic": false,
      "signature": "{ currency, total, items: [{ productId, name, price, quantity }] }",
      "example": "window.trevio.viewCart({ currency: 'PLN', total: 99.98, items: [{ productId: 'SKU-1', name: 'Koszulka', price: 49.99, quantity: 2 }] })"
     },
     {
      "method": "window.trevio.beginCheckout",
      "eventType": "BeginCheckout",
      "automatic": false,
      "signature": "{ currency, total, items: [{ productId, name, price, quantity }] }",
      "example": "window.trevio.beginCheckout({ currency: 'PLN', total: 99.98, items: [{ productId: 'SKU-1', name: 'Koszulka', price: 49.99, quantity: 2 }] })"
     },
     {
      "method": "window.trevio.addShippingInfo",
      "eventType": "AddShippingInfo",
      "automatic": false,
      "signature": "{ currency, total, deliveryMethod, deliveryCost, items }",
      "example": "window.trevio.addShippingInfo({ currency: 'PLN', total: 99.98, deliveryMethod: 'Kurier', deliveryCost: 15, items: [{ productId: 'SKU-1', name: 'Koszulka', price: 49.99, quantity: 2 }] })"
     },
     {
      "method": "window.trevio.addPaymentInfo",
      "eventType": "AddPaymentInfo",
      "automatic": false,
      "signature": "{ currency, total, paymentType, items }",
      "example": "window.trevio.addPaymentInfo({ currency: 'PLN', total: 99.98, paymentType: 'card', items: [{ productId: 'SKU-1', name: 'Koszulka', price: 49.99, quantity: 2 }] })"
     },
     {
      "method": "window.trevio.paymentInitiated",
      "eventType": "PaymentInitiated",
      "automatic": false,
      "signature": "{ currency, orderId, orderNumber, total }",
      "example": "window.trevio.paymentInitiated({ currency: 'PLN', orderId: '1001', orderNumber: 'ORD-1001', total: 99.98 })"
     },
     {
      "method": "window.trevio.purchase",
      "eventType": "Purchase",
      "automatic": false,
      "signature": "{ currency, orderId, orderNumber, total, items: [{ productId, name, price, quantity }], isCashOnDelivery }",
      "example": "window.trevio.purchase({ currency: 'PLN', orderId: '1001', orderNumber: 'ORD-1001', total: 99.98, items: [{ productId: 'SKU-1', name: 'Koszulka', price: 49.99, quantity: 2 }], isCashOnDelivery: false })"
     },
     {
      "method": "window.trevio.purchaseOnDelivery",
      "eventType": "PurchaseOnDelivery",
      "automatic": false,
      "signature": "{ currency, orderId, orderNumber, total, items: [{ productId, name, price, quantity }] }",
      "example": "window.trevio.purchaseOnDelivery({ currency: 'PLN', orderId: '1001', orderNumber: 'ORD-1001', total: 99.98, items: [{ productId: 'SKU-1', name: 'Koszulka', price: 49.99, quantity: 2 }] })"
     },
     {
      "method": "window.trevio.search",
      "eventType": "Search",
      "automatic": false,
      "signature": "{ query }",
      "example": "window.trevio.search({ query: 'buty do biegania' })"
     },
     {
      "method": "window.trevio.identify",
      "eventType": "Identify",
      "automatic": false,
      "signature": "{ identityType, value }",
      "example": "window.trevio.identify({ identityType: 'CustomerId', value: '3fa85f64-5717-4562-b3fc-2c963f66afa6' })"
     },
     {
      "method": "window.trevio.newsletterSubscribe",
      "eventType": "NewsletterSubscribe",
      "automatic": false,
      "signature": "{ email }",
      "example": "window.trevio.newsletterSubscribe({ email: 'klient@example.com' })"
     },
     {
      "method": "window.trevio.emailCampaignClick",
      "eventType": "EmailCampaignClick",
      "automatic": false,
      "signature": "{ trvclid, campaignId, emailSendId }",
      "example": "window.trevio.emailCampaignClick({ trvclid: 'abc', campaignId: 'cmp-1', emailSendId: 'snd-1' })"
     }
    ]
   }
  }
 ]
}