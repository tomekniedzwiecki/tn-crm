{
  "manifest_version": 3,
  "name": "TN Ads Filler",
  "version": "1.0.0",
  "description": "Wypełnia formularze reklam Meta Ads kopiami z CRM (workflow_ads.ad_copies.versions)",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TN Ads Filler"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "fill-all-variants": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      },
      "description": "Wypełnij wszystkie warianty na aktywnym workflow"
    }
  }
}
